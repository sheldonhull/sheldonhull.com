---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sheldon Hull",
  description = "Tech blog and digital garden by Sheldon Hull"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-[var(--sw-text-primary)]" style="background: var(--sw-bg-primary);">
    <!-- SVG Filters for Liquid Glass Distortion -->
    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position: absolute; overflow: hidden;">
      <defs>
        <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
          <!-- Generate fractal noise for organic distortion -->
          <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
          <!-- Smooth the noise for realistic glass refraction -->
          <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
          <!-- Apply displacement mapping for liquid glass effect -->
          <feDisplacementMap in="SourceGraphic" in2="blurred" scale="77" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>

    <nav class="liquid-glass-header">
      <div class="container mx-auto px-4 py-4 relative z-10">
        <div class="flex items-center justify-between">
          <a href="/" class="text-xl font-bold transition-all duration-300 hover:scale-105 neon-glow-cyan" style="color: var(--sw-cyan);">
            Sheldon Hull
          </a>
          <div class="flex gap-6">
            <a href="/" class="nav-link transition-all duration-300 hover:text-[var(--sw-cyan)] hover:scale-105" style="color: var(--sw-text-secondary);">Home</a>
            <a href="/posts" class="nav-link transition-all duration-300 hover:text-[var(--sw-cyan)] hover:scale-105" style="color: var(--sw-text-secondary);">Posts</a>
            <a href="/about" class="nav-link transition-all duration-300 hover:text-[var(--sw-cyan)] hover:scale-105" style="color: var(--sw-text-secondary);">About</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-4 py-12 mt-8">
      <slot />
    </main>

    <footer class="border-t mt-16" style="border-color: var(--sw-bg-tertiary); background: var(--sw-bg-secondary);">
      <div class="container mx-auto px-4 py-8 text-center text-sm" style="color: var(--sw-text-muted);">
        <p>&copy; {new Date().getFullYear()} Sheldon Hull. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
