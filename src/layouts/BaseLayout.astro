---
import '../styles/global.css';
import LiquidGlassHeader from '../components/LiquidGlassHeader.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sheldon Hull",
  description = "Tech blog and digital garden by Sheldon Hull"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-[var(--sw-text-primary)]" style="background: var(--sw-bg-primary);">
    <!-- SVG Filters for Liquid Glass Distortion -->
    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position: absolute; overflow: hidden;">
      <defs>
        <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
          <!-- Generate fractal noise for organic distortion -->
          <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
          <!-- Smooth the noise for realistic glass refraction -->
          <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
          <!-- Apply displacement mapping for liquid glass effect -->
          <feDisplacementMap in="SourceGraphic" in2="blurred" scale="77" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>

    <LiquidGlassHeader />

    <main class="container mx-auto px-4 py-12 mt-12">
      <slot />
    </main>

    <footer class="site-footer border-t mt-16" style="border-color: var(--sw-bg-tertiary); background: var(--sw-bg-secondary);">
      <div class="container mx-auto px-4 py-8 text-center text-sm" style="color: var(--sw-text-muted);">
        <p>
          &copy; {new Date().getFullYear()} Sheldon Hull.
          Built with <span class="footer-heart" title="Click me!">♥</span> and
          <span class="footer-taco" title="My spirit animal">🌮</span>
        </p>
      </div>
    </footer>

    <!-- Konami code overlay (hidden until activated) -->
    <div id="konami-overlay" class="konami-overlay" aria-hidden="true">
      <div class="konami-content">
        <p class="konami-text">⬆⬆⬇⬇⬅➡⬅➡🅱🅰</p>
        <p class="konami-sub">You found the secret! Here's a taco: 🌮</p>
      </div>
    </div>

    <style>
      /* Footer whimsy */
      .footer-heart {
        color: var(--sw-pink);
        cursor: pointer;
        display: inline-block;
        transition: transform 0.2s ease;
      }

      .footer-heart:hover {
        animation: heartbeat 0.6s ease-in-out;
      }

      @keyframes heartbeat {
        0%, 100% { transform: scale(1); }
        25% { transform: scale(1.3); }
        50% { transform: scale(1); }
        75% { transform: scale(1.2); }
      }

      .footer-taco {
        cursor: pointer;
        display: inline-block;
        transition: transform 0.3s ease;
      }

      .footer-taco:hover {
        animation: tacoWiggle 0.5s ease-in-out;
      }

      @keyframes tacoWiggle {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-12deg); }
        75% { transform: rotate(12deg); }
      }

      /* Konami code overlay */
      .konami-overlay {
        position: fixed;
        inset: 0;
        z-index: 99999;
        background: rgba(1, 22, 39, 0.95);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
      }

      .konami-overlay.active {
        opacity: 1;
        pointer-events: auto;
      }

      .konami-content {
        text-align: center;
      }

      .konami-text {
        font-size: clamp(2rem, 5vw, 4rem);
        letter-spacing: 0.1em;
        animation: konamiGlow 2s ease-in-out infinite alternate;
      }

      .konami-sub {
        font-size: 1.25rem;
        color: var(--sw-cyan);
        margin-top: 1rem;
      }

      @keyframes konamiGlow {
        from {
          text-shadow: 0 0 10px rgba(255, 88, 116, 0.5), 0 0 20px rgba(199, 146, 234, 0.3);
        }
        to {
          text-shadow: 0 0 20px rgba(127, 219, 202, 0.5), 0 0 40px rgba(255, 88, 116, 0.3);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .footer-heart:hover,
        .footer-taco:hover {
          animation: none !important;
        }
      }
    </style>

    <script>
      // Console easter egg
      console.log(
        '%c⚡ sheldonhull.com %c\n' +
        '%cMaking infrastructure dance since 2015.\n' +
        'Built with Astro, Tailwind, and too much coffee.\n\n' +
        'Curious? → https://github.com/sheldonhull/sheldonhull.com\n' +
        'Psst... try the Konami code.',
        'font-size: 20px; font-weight: bold; color: #7fdbca; text-shadow: 0 0 10px #7fdbca;',
        '',
        'font-size: 12px; color: #c792ea;'
      );

      // Konami code: ↑↑↓↓←→←→BA
      const konamiSequence = [38,38,40,40,37,39,37,39,66,65];
      let konamiIndex = 0;

      document.addEventListener('keydown', (e) => {
        if (e.keyCode === konamiSequence[konamiIndex]) {
          konamiIndex++;
          if (konamiIndex === konamiSequence.length) {
            const overlay = document.getElementById('konami-overlay');
            overlay?.classList.add('active');
            konamiIndex = 0;

            // Dismiss on click or Escape
            const dismiss = () => {
              overlay?.classList.remove('active');
              overlay?.removeEventListener('click', dismiss);
              document.removeEventListener('keydown', escDismiss);
            };
            const escDismiss = (evt) => {
              if (evt.key === 'Escape') dismiss();
            };
            overlay?.addEventListener('click', dismiss);
            document.addEventListener('keydown', escDismiss);
          }
        } else {
          konamiIndex = 0;
        }
      });

      // Footer heart click — spawns floating hearts
      document.querySelector('.footer-heart')?.addEventListener('click', (e) => {
        for (let i = 0; i < 5; i++) {
          const heart = document.createElement('span');
          heart.textContent = '♥';
          heart.style.cssText = `
            position: fixed;
            left: ${e.clientX + (Math.random() - 0.5) * 40}px;
            top: ${e.clientY}px;
            color: var(--sw-pink);
            font-size: ${14 + Math.random() * 12}px;
            pointer-events: none;
            z-index: 9999;
            opacity: 1;
            transition: all 1s cubic-bezier(0.25, 1, 0.5, 1);
          `;
          document.body.appendChild(heart);
          requestAnimationFrame(() => {
            heart.style.transform = `translateY(-${60 + Math.random() * 60}px) rotate(${(Math.random() - 0.5) * 40}deg)`;
            heart.style.opacity = '0';
          });
          setTimeout(() => heart.remove(), 1000);
        }
      });

      // Footer taco click — spawns floating tacos
      document.querySelector('.footer-taco')?.addEventListener('click', (e) => {
        for (let i = 0; i < 3; i++) {
          const taco = document.createElement('span');
          taco.textContent = '🌮';
          taco.style.cssText = `
            position: fixed;
            left: ${e.clientX + (Math.random() - 0.5) * 30}px;
            top: ${e.clientY}px;
            font-size: ${16 + Math.random() * 10}px;
            pointer-events: none;
            z-index: 9999;
            opacity: 1;
            transition: all 1.2s cubic-bezier(0.25, 1, 0.5, 1);
          `;
          document.body.appendChild(taco);
          requestAnimationFrame(() => {
            taco.style.transform = `translateY(-${50 + Math.random() * 50}px) rotate(${(Math.random() - 0.5) * 60}deg)`;
            taco.style.opacity = '0';
          });
          setTimeout(() => taco.remove(), 1200);
        }
      });
    </script>
  </body>
</html>
