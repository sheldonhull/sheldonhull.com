---
import { codeToHtml } from 'shiki';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  user: string;
  gistId: string;
  filename?: string;
  title?: string;
  lang?: string;
  theme?: string;
}

const {
  user,
  gistId,
  filename,
  title = filename || 'Code',
  lang = 'typescript',
  theme = 'night-owl'
} = Astro.props;

// Generate unique ID for SVG filter to avoid conflicts with multiple gists
const filterId = `glass-distortion-${gistId.substring(0, 8)}`;

// Setup cache directory - use .netlify/cache for Netlify builds, node_modules/.cache locally
const cacheDir = process.env.NETLIFY
  ? path.join(process.cwd(), '.netlify', 'cache', 'gists')
  : path.join(process.cwd(), 'node_modules', '.cache', 'gists');
const cacheFile = path.join(cacheDir, `${gistId}.json`);

// Fetch gist data from GitHub API at build time with caching
const apiUrl = `https://api.github.com/gists/${gistId}`;
let gistContent = '';
let detectedLanguage = lang;
let gistUrl = `https://gist.github.com/${user}/${gistId}`;

// Use GitHub token if available for higher rate limits (5000/hr vs 60/hr)
const headers: HeadersInit = {
  'Accept': 'application/vnd.github+json',
  'X-GitHub-Api-Version': '2022-11-28'
};

const githubToken = import.meta.env.GITHUB_TOKEN || process.env.GITHUB_TOKEN;
if (githubToken) {
  headers['Authorization'] = `Bearer ${githubToken}`;
}

let gistData: any;

try {
  // Check if cached version exists
  if (fs.existsSync(cacheFile)) {
    const cachedData = fs.readFileSync(cacheFile, 'utf-8');
    gistData = JSON.parse(cachedData);
    console.log(`Using cached gist data for ${gistId}`);
  } else {
    // Fetch from GitHub API
    const response = await fetch(apiUrl, { headers });
    if (!response.ok) {
      throw new Error(`GitHub API error: ${response.status}`);
    }

    gistData = await response.json();

    // Cache the response
    fs.mkdirSync(cacheDir, { recursive: true });
    fs.writeFileSync(cacheFile, JSON.stringify(gistData, null, 2));
    console.log(`Cached gist data for ${gistId}`);
  }

  // Get the specific file or first file
  if (filename && gistData.files[filename]) {
    gistContent = gistData.files[filename].content;
    detectedLanguage = gistData.files[filename].language?.toLowerCase() || lang;
  } else if (filename) {
    // Requested file not found - show available files
    const availableFiles = Object.keys(gistData.files).join(', ');
    console.error(`File "${filename}" not found in gist. Available files: ${availableFiles}`);
    gistContent = `// Error: File "${filename}" not found in gist\n// Available files: ${availableFiles}`;
  } else {
    // Get first file
    const firstFile = Object.values(gistData.files)[0] as any;
    gistContent = firstFile.content;
    detectedLanguage = firstFile.language?.toLowerCase() || lang;
    gistUrl += `#file-${firstFile.filename.replace(/\./g, '-')}`;
  }
} catch (error) {
  console.error('Error fetching gist:', error);
  gistContent = `// Error loading gist content: ${error}`;
}

// Map GitHub language names to Shiki-compatible names
const languageMap: Record<string, string> = {
  'ignore list': 'text',
  'shell': 'bash',
  'shell script': 'bash',
};

// Apply language mapping and fallback
const mappedLanguage = languageMap[detectedLanguage] || detectedLanguage;

// Syntax highlight with Shiki
let highlighted: string;
try {
  highlighted = await codeToHtml(gistContent, {
    lang: mappedLanguage,
    theme: theme,
    structure: 'classic'
  });
} catch (err) {
  // If language is not supported, fall back to plaintext
  console.warn(`Language "${mappedLanguage}" not supported by Shiki, falling back to text`);
  highlighted = await codeToHtml(gistContent, {
    lang: 'text',
    theme: theme,
    structure: 'classic'
  });
}
---

<!-- SVG Filter Definition for True Liquid Glass Distortion -->
<svg class="absolute w-0 h-0" aria-hidden="true">
  <defs>
    <filter id={filterId} x="0%" y="0%" width="100%" height="100%">
      <!-- Create fractal noise for organic liquid texture with animation -->
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.01 0.01"
        numOctaves="2"
        result="turbulence"
      >
        <animate
          attributeName="baseFrequency"
          values="0.01 0.01;0.015 0.012;0.01 0.01"
          dur="10s"
          repeatCount="indefinite"
        />
      </feTurbulence>

      <!-- Smooth the turbulence -->
      <feGaussianBlur in="turbulence" stdDeviation="3" result="blur" />

      <!-- Add specular lighting for glass reflection -->
      <feSpecularLighting
        in="blur"
        surfaceScale="5"
        specularConstant="0.75"
        specularExponent="20"
        lighting-color="#93c5fd"
        result="specular"
      >
        <fePointLight x="-200" y="-200" z="300" />
      </feSpecularLighting>

      <!-- Composite the lighting -->
      <feComposite
        in="specular"
        in2="SourceAlpha"
        operator="in"
        result="specularComposite"
      />

      <!-- Apply displacement for liquid distortion with animated scale -->
      <feDisplacementMap
        in="SourceGraphic"
        in2="blur"
        scale="25"
        xChannelSelector="R"
        yChannelSelector="G"
      >
        <animate
          attributeName="scale"
          values="20;30;20"
          dur="8s"
          repeatCount="indefinite"
        />
      </feDisplacementMap>
    </filter>
  </defs>
</svg>

<div class="gist-window-container group my-8">
  <div class="gist-window liquid-glass-morph relative overflow-hidden rounded-xl border border-white/10 bg-slate-900/90 shadow-2xl transition-all duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:shadow-[0_25px_80px_rgba(0,0,0,0.6),0_0_60px_rgba(147,197,253,0.2)] active:scale-[0.98]">

    <div class="relative z-10">

    <!-- macOS Window Chrome with Liquid Glass Effect -->
    <div class="window-chrome-wrapper relative">
      <!-- SVG Liquid Glass Effect Layer - ONLY on titlebar -->
      <div class="liquid-glass-effect absolute inset-0 rounded-t-xl pointer-events-none opacity-40 transition-all duration-700 group-hover:opacity-70" style={`filter: url(#${filterId})`}></div>

      <!-- Tint Layer for glass color -->
      <div class="liquid-glass-tint absolute inset-0 rounded-t-xl bg-gradient-to-br from-cyan-500/10 via-purple-500/10 to-pink-500/10 pointer-events-none transition-opacity duration-500 group-hover:opacity-80"></div>

      <!-- Shine Layer for glass highlights -->
      <div class="liquid-glass-shine absolute inset-0 rounded-t-xl pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-500" style="box-shadow: inset 3px 3px 2px 0 rgba(255, 255, 255, 0.4), inset -2px -2px 2px 2px rgba(255, 255, 255, 0.3);"></div>

      <!-- Liquid ripple overlay -->
      <div class="liquid-ripple-overlay absolute inset-0 rounded-t-xl pointer-events-none opacity-0"></div>

    <div class="window-chrome relative z-10 flex items-center gap-4 border-b border-white/5 bg-slate-800/60 backdrop-blur-[40px] backdrop-saturate-[180%] px-4 py-3 transition-all duration-500 group-hover:backdrop-blur-[60px]">

      <!-- Control Dots -->
      <div class="chrome-buttons flex gap-2">
        <button
          class="chrome-dot close relative h-3 w-3 rounded-full bg-gradient-to-br from-red-500 to-red-600 shadow-sm ring-1 ring-black/20 transition-all hover:ring-2 hover:ring-red-400/50"
          aria-label="Close"
        >
          <span class="dot-icon absolute inset-0 flex items-center justify-center text-[8px] font-bold text-black/70 opacity-0 transition-opacity group-hover:opacity-100">×</span>
        </button>
        <button
          class="chrome-dot minimize relative h-3 w-3 rounded-full bg-gradient-to-br from-yellow-500 to-yellow-600 shadow-sm ring-1 ring-black/20 transition-all hover:ring-2 hover:ring-yellow-400/50"
          aria-label="Minimize"
        >
          <span class="dot-icon absolute inset-0 flex items-center justify-center text-[8px] font-bold text-black/70 opacity-0 transition-opacity group-hover:opacity-100">−</span>
        </button>
        <button
          class="chrome-dot maximize relative h-3 w-3 rounded-full bg-gradient-to-br from-green-500 to-green-600 shadow-sm ring-1 ring-black/20 transition-all hover:ring-2 hover:ring-green-400/50"
          aria-label="Maximize"
        >
          <span class="dot-icon absolute inset-0 flex items-center justify-center text-[8px] font-bold text-black/70 opacity-0 transition-opacity group-hover:opacity-100">+</span>
        </button>
      </div>

      <!-- Title -->
      <div class="chrome-title flex-1 text-center text-sm font-medium text-slate-300">
        {title}
      </div>

      <!-- Actions -->
      <div class="chrome-actions">
        <a
          href={gistUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-7 items-center gap-1.5 rounded-md bg-slate-800/50 px-2.5 text-xs text-slate-400 transition-colors hover:bg-slate-700/50 hover:text-slate-300"
          title="View on GitHub"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
      </div>
    </div>
    </div> <!-- Close window-chrome-wrapper -->

    <!-- Code Content with stable background -->
    <div class="window-content relative bg-slate-900">
      <!-- Copy Button -->
      <button
        class="copy-button absolute right-3 top-3 z-10 rounded-md border border-white/10 bg-slate-800/80 px-3 py-1.5 text-xs text-slate-300 backdrop-blur-sm transition-all hover:bg-slate-700/80 hover:text-white active:scale-95"
        data-code={gistContent}
        aria-label="Copy code"
      >
        <span class="copy-text">Copy</span>
        <span class="copied-text hidden">✓ Copied!</span>
      </button>

      <!-- Syntax Highlighted Code -->
      <div class="code-block overflow-x-auto">
        <Fragment set:html={highlighted} />
      </div>
    </div>
    </div> <!-- Close relative z-10 wrapper -->
  </div>
</div>

<style>
  /* Scroll animation setup */
  .scroll-animate {
    opacity: 0;
    transform: translateY(30px) scale(0.98);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .scroll-animate.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ============================================ */
  /* LIQUID GLASS EFFECTS */
  /* ============================================ */

  /* Liquid glass morphing animation - more dramatic and visible */
  @keyframes liquid-morph {
    0%, 100% {
      backdrop-filter: blur(40px) saturate(180%) brightness(1);
    }
    50% {
      backdrop-filter: blur(48px) saturate(200%) brightness(1.05);
    }
  }

  /* Liquid shimmer animation for border - enhanced */
  @keyframes liquid-shimmer {
    0% {
      background-position: 0% 50%;
      opacity: 0.5;
    }
    50% {
      background-position: 100% 50%;
      opacity: 1;
    }
    100% {
      background-position: 0% 50%;
      opacity: 0.5;
    }
  }

  /* Liquid ripple effect */
  @keyframes liquid-ripple {
    0% {
      transform: scale(0);
      opacity: 0.8;
    }
    50% {
      opacity: 0.4;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Glass wobble on click - subtle movement */
  @keyframes liquid-wobble {
    0%, 100% {
      transform: translateY(-2px) scale(1) rotate(0deg);
    }
    25% {
      transform: translateY(-1px) scale(0.995) rotate(-0.5deg);
    }
    50% {
      transform: translateY(-3px) scale(1.005) rotate(0.5deg);
    }
    75% {
      transform: translateY(-2px) scale(0.998) rotate(-0.25deg);
    }
  }

  /* Pulsing glow effect */
  @keyframes liquid-glow {
    0%, 100% {
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.5),
        0 0 40px rgba(147, 197, 253, 0.1);
    }
    50% {
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.5),
        0 0 60px rgba(147, 197, 253, 0.3),
        0 0 80px rgba(167, 139, 250, 0.2);
    }
  }

  /* Base liquid glass morphing styles - stable window */
  .liquid-glass-morph {
    will-change: transform;
    /* Smooth transitions for scroll-based jelly wobble */
    transition: transform 0.1s ease-out;
  }

  /* Enhanced glassmorphism on hover with pulsing glow */
  .gist-window-container:hover .liquid-glass-morph {
    animation: liquid-glow 3s ease-in-out infinite;
  }

  /* Window chrome wrapper - contains liquid glass effects */
  .window-chrome-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem 0.75rem 0 0; /* Rounded top corners only */
  }

  /* Liquid glass effect layer - only on titlebar */
  .liquid-glass-effect {
    background: rgba(147, 197, 253, 0.02);
  }

  /* Animated shimmer border */
  .liquid-border {
    background-size: 200% 200%;
    animation: liquid-shimmer 4s ease infinite;
  }

  /* Liquid ripple overlay styling - more visible */
  .liquid-ripple-overlay {
    background: radial-gradient(circle at center, rgba(147, 197, 253, 0.4) 0%, transparent 70%);
    transition: opacity 0.3s ease;
    border-radius: inherit;
    mix-blend-mode: screen;
  }

  /* Wobble animation on click - subtle */
  .liquid-glass-morph.wobble {
    animation: liquid-wobble 0.5s ease-out;
  }

  /* Glass refraction effect removed - too much motion */
  /* Keeping the keyframe definition in case we want to re-enable */
  @keyframes glass-shine {
    0% {
      left: -100%;
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      left: 200%;
      opacity: 0;
    }
  }

  /* Code content - stable background, no color shifting */
  .window-content {
    background: rgb(15, 23, 42) !important; /* Solid slate-900 */
    isolation: isolate; /* Prevent filter effects from parent */
  }

  .gist-window-container :global(.shiki) {
    background: rgb(15, 23, 42) !important; /* Solid slate-900 - prevents color shifting */
    margin: 0;
    padding: 0;
  }

  .gist-window-container :global(.shiki code) {
    display: block;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1.rem;
    font-size: 0.875rem;
    line-height: 1.625;
    background: inherit; /* Inherit stable background */
  }

  .gist-window-container :global(.shiki .line) {
    min-height: 1.5rem;
  }

  /* Scrollbar styling with liquid glass effect */
  .code-block {
    scrollbar-width: thin;
    scrollbar-color: rgba(148, 163, 184, 0.3) transparent;
  }

  .code-block::-webkit-scrollbar {
    height: 8px;
  }

  .code-block::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }

  .code-block::-webkit-scrollbar-thumb {
    background: linear-gradient(90deg,
      rgba(147, 197, 253, 0.3) 0%,
      rgba(167, 139, 250, 0.3) 50%,
      rgba(244, 114, 182, 0.3) 100%);
    border-radius: 4px;
    transition: background 0.3s;
  }

  .code-block::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(90deg,
      rgba(147, 197, 253, 0.5) 0%,
      rgba(167, 139, 250, 0.5) 50%,
      rgba(244, 114, 182, 0.5) 100%);
  }
</style>

<script>
  // Initialize function
  function initGistEffects() {
    // ============================================
    // LIQUID GLASS INTERACTIVE EFFECTS
    // ============================================

    // Add wobble effect to gist windows
    const gistWindows = document.querySelectorAll('.gist-window.liquid-glass-morph');

    gistWindows.forEach((window) => {
      // Subtle wobble on mousedown
      window.addEventListener('mousedown', function(e) {
        this.classList.add('wobble');
        setTimeout(() => this.classList.remove('wobble'), 500);
      });
    });

    // Copy button functionality
    const copyButtons = document.querySelectorAll('.copy-button');

    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const code = button.getAttribute('data-code');
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);

          // Show feedback
          const copyText = button.querySelector('.copy-text');
          const copiedText = button.querySelector('.copied-text');

          if (copyText && copiedText) {
            copyText.classList.add('hidden');
            copiedText.classList.remove('hidden');
            button.classList.add('bg-green-600/80', 'border-green-500/50');

            setTimeout(() => {
              copyText.classList.remove('hidden');
              copiedText.classList.add('hidden');
              button.classList.remove('bg-green-600/80', 'border-green-500/50');
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });

    // Scroll animation with flex effect and liquid glass activation
    const gistContainers = document.querySelectorAll('.gist-window-container');

    // Intersection Observer for initial fade-in and liquid glass activation
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    }, observerOptions);

    gistContainers.forEach(container => {
      observer.observe(container);
    });

    // Scroll-based parallax flex effect
    let ticking = false;

    function updateGistPositions() {
      gistContainers.forEach(container => {
        if (!container.classList.contains('in-view')) return;

        const rect = container.getBoundingClientRect();
        const viewportHeight = window.innerHeight;

        // Only apply effect when element is visible
        if (rect.top < viewportHeight && rect.bottom > 0) {
          // Calculate scroll progress (0 to 1) as element moves through viewport
          const scrollProgress = 1 - (rect.top + rect.height / 2) / viewportHeight;
          const clampedProgress = Math.max(0, Math.min(1, scrollProgress));

          // Apply liquid jelly wobble effect - subtle movement
          const gistWindow = container.querySelector('.gist-window.liquid-glass-morph');
          if (gistWindow) {
            // Jelly wave motion - subtle
            const flex = Math.sin(clampedProgress * Math.PI * 2) * 3; // Subtle wobble up/down

            // Scale wobble - very subtle jelly squish effect
            const scaleX = 1 + (Math.sin(clampedProgress * Math.PI * 2) * 0.008);
            const scaleY = 1 - (Math.sin(clampedProgress * Math.PI * 2) * 0.005);

            // Rotation wobble - liquid sway
            const rotation = Math.sin(clampedProgress * Math.PI * 2) * 0.3;

            gistWindow.style.transform = `translateY(${flex}px) scale(${scaleX}, ${scaleY}) rotate(${rotation}deg)`;
          }
        }
      });

      ticking = false;
    }

    function requestTickFunction() {
      if (!ticking) {
        window.requestAnimationFrame(updateGistPositions);
        ticking = true;
      }
    }

    // Throttled scroll listener
    window.addEventListener('scroll', requestTickFunction, { passive: true });

    // Initial position update
    updateGistPositions();
  } // End initGistEffects

  // Run on Astro page load
  document.addEventListener('astro:page-load', () => {
    initGistEffects();
  });

  // Also run immediately in case astro:page-load doesn't fire
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initGistEffects();
    });
  } else {
    initGistEffects();
  }
</script>
