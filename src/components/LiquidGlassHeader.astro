---
// Liquid glass header with glassmorphism backdrop
// Includes scroll-based quote rotation and avatar spin animation
import { headerQuotes } from '../config/site';

const currentPath = Astro.url.pathname;
---

<!-- SVG filter removed: continuous feTurbulence animation caused text jitter -->

<div class="liquid-glass-header" id="liquid-header">
  <div class="container mx-auto px-4 py-4 relative z-10 liquid-text-container">
    <div class="flex items-center justify-between header-content">
      <a href="/" class="flex items-center gap-3 text-xl font-bold transition-all duration-300 hover:scale-105 neon-glow-cyan header-logo-link" style="color: var(--sw-cyan);">
        <!-- Avatar container with fixed width to prevent overlap -->
        <div id="avatar-container" class="relative flex-shrink-0" style="width: 2.5rem; height: 2.5rem;">
          <!-- Circular avatar -->
          <img
            id="avatar-logo"
            src="/avatar-skitch-sheldon.png"
            alt="Sheldon Hull Avatar"
            class="w-10 h-10 rounded-full avatar-image"
            style="transition: transform 600ms ease;"
          />
          <!-- Speech bubble -->
          <div id="speech-bubble" class="speech-bubble">
            Greetings & Salutations!
          </div>
        </div>
        <!-- Text container for overlapping title/quote -->
        <div class="relative site-title-container">
          <!-- Site name (default) -->
          <span id="site-name" class="header-text transition-opacity duration-500">sheldonhull.com</span>
          <!-- Tech quote (scrolled) - absolutely positioned to overlay site name exactly -->
          <span id="tech-quote" class="header-text absolute top-0 left-0 opacity-0 transition-opacity duration-500 whitespace-nowrap" style="color: var(--sw-cyan);">
          </span>
        </div>
      </a>
      <nav class="nav-links-container">
        <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>Home</a>
        <a href="/posts" class:list={["nav-link", { active: currentPath === "/posts" || currentPath === "/posts/" }]}>Posts</a>
        <a href="/notes" class:list={["nav-link", { active: currentPath === "/notes" || currentPath === "/notes/" }]}>Notes</a>
        <a href="/tags" class:list={["nav-link", { active: currentPath === "/tags" || currentPath === "/tags/" }]}>Tags</a>
        <a href="/about" class:list={["nav-link", { active: currentPath === "/about" || currentPath === "/about/" }]}>About</a>
      </nav>
    </div>
  </div>
</div>

<style>
  .liquid-text-container {
    /* SVG filter removed — feTurbulence animation caused constant text jitter */
  }

  .header-text {
    transition: opacity 500ms ease;
    position: relative;
    z-index: 1;
  }

  /* Nav link styling */
  .nav-link {
    color: var(--sw-text-secondary);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.25s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--sw-cyan);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    border-radius: 1px;
  }

  .nav-link:hover {
    color: var(--sw-cyan);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* Active nav link */
  .nav-link.active {
    color: var(--sw-cyan);
    font-weight: 600;
  }

  .nav-link.active::after {
    transform: scaleX(1);
    background: var(--sw-pink);
    box-shadow: 0 0 6px rgba(255, 88, 116, 0.5);
  }

  /* Desktop nav spacing */
  .nav-links-container {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  /* Mobile: hide quote feature and site title text */
  @media (max-width: 767px) {
    #tech-quote {
      display: none !important;
    }

    /* Hide site title text, keep only icon */
    .site-title-container {
      display: none !important;
    }

    /* Adjust header content for mobile */
    .header-content {
      gap: 0.5rem;
    }

    /* Logo link adjustments */
    .header-logo-link {
      gap: 0 !important;
      flex-shrink: 0;
    }

    /* Make nav links horizontally scrollable */
    .nav-links-container {
      display: flex;
      gap: 1.5rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE and Edge */
      padding: 0.25rem 0;
      margin-left: 1.5rem;
      flex: 1;
      min-width: 0;
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    .nav-links-container::-webkit-scrollbar {
      display: none;
    }

    /* Nav link mobile adjustments */
    .nav-links-container .nav-link {
      flex-shrink: 0;
      white-space: nowrap;
      font-size: 0.95rem;
      padding: 0.25rem 0.5rem;
    }
  }

  /* Avatar hover peek and wobble animation */
  @keyframes peekAndWobble {
    0% {
      transform: scale(1) rotateZ(0deg) rotateY(0deg);
    }
    15% {
      transform: scale(4) rotateZ(0deg) rotateY(0deg);
    }
    25% {
      transform: scale(4) rotateZ(-8deg) rotateY(-15deg);
    }
    35% {
      transform: scale(4) rotateZ(8deg) rotateY(15deg);
    }
    45% {
      transform: scale(4) rotateZ(-8deg) rotateY(-15deg);
    }
    55% {
      transform: scale(4) rotateZ(8deg) rotateY(15deg);
    }
    65% {
      transform: scale(4) rotateZ(0deg) rotateY(0deg);
    }
    100% {
      transform: scale(4) rotateZ(0deg) rotateY(0deg);
    }
  }

  @keyframes speechBubblePop {
    0% {
      opacity: 0;
      transform: scale(0.4) translateY(8px);
      filter: blur(4px);
    }
    50% {
      opacity: 1;
      transform: scale(1.06) translateY(-2px);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
      filter: blur(0);
    }
  }

  .avatar-image.peeking {
    animation: peekAndWobble 1.4s ease-in-out forwards;
    position: relative;
    z-index: 10000;
    transform-origin: top left;
    transform-style: preserve-3d;
    backface-visibility: visible;
  }

  .avatar-image {
    cursor: pointer;
    transform-origin: center center;
    position: relative;
    transform-style: preserve-3d;
    z-index: 50;
  }

  #avatar-container {
    cursor: pointer;
    perspective: 1000px;
    transform-style: preserve-3d;
    position: relative;
    z-index: 9998;
    isolation: isolate;
  }

  .speech-bubble {
    position: fixed;
    top: 70px;
    left: 180px;
    background: rgba(1, 22, 39, 0.92);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    color: var(--sw-cyan);
    padding: 0.75rem 1.25rem;
    border-radius: 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    white-space: nowrap;
    opacity: 0;
    z-index: 9999;
    pointer-events: none;
    border: 1.5px solid rgba(127, 219, 202, 0.35);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.4),
      0 0 15px rgba(127, 219, 202, 0.15),
      inset 0 1px 0 rgba(127, 219, 202, 0.1);
  }

  /* Triangle tail pointing at avatar */
  .speech-bubble::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -8px;
    width: 14px;
    height: 14px;
    background: rgba(1, 22, 39, 0.92);
    border-left: 1.5px solid rgba(127, 219, 202, 0.35);
    border-bottom: 1.5px solid rgba(127, 219, 202, 0.35);
    transform: translateY(-50%) rotate(45deg);
    z-index: -1;
  }

  /* Remove the old second thought-bubble circle */
  .speech-bubble::after {
    content: none;
  }

  .speech-bubble.show {
    animation: speechBubblePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
</style>

<script define:vars={{ techQuotes: headerQuotes }}>
  // Tech shower thought quotes loaded from site config

  function initHeaderScrollEffect() {
    // Skip on mobile
    if (window.innerWidth < 768) {
      return;
    }

    const avatarLogo = document.getElementById('avatar-logo');
    const siteName = document.getElementById('site-name');
    const techQuote = document.getElementById('tech-quote');

    if (!avatarLogo || !siteName || !techQuote) {
      return;
    }

    let isScrolled = false;
    let ticking = false;
    let lastScrollTop = 0;

    // Get random quote
    function getRandomQuote() {
      return techQuotes[Math.floor(Math.random() * techQuotes.length)];
    }

    // Handle scroll state change
    function updateHeaderState() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      const scrollThreshold = 50;

      // Detect if we just scrolled from top
      const wasAtTop = lastScrollTop <= scrollThreshold;
      const isAtTop = scrollTop <= scrollThreshold;
      const justScrolledDown = wasAtTop && !isAtTop;

      if (scrollTop > scrollThreshold && !isScrolled) {
        // Scrolled down - show quote and rotate avatar
        isScrolled = true;

        // Pick new quote
        techQuote.textContent = getRandomQuote();

        // Rotate avatar and swap text
        avatarLogo.style.transform = 'rotate(360deg)';
        siteName.style.opacity = '0';

        // Delay quote fade-in slightly for smoother effect
        setTimeout(() => {
          techQuote.style.opacity = '0.6';
        }, 200);

      } else if (scrollTop <= scrollThreshold && isScrolled) {
        // Scrolled back to top - restore original state
        isScrolled = false;

        avatarLogo.style.transform = 'rotate(0deg)';
        siteName.style.opacity = '1';
        techQuote.style.opacity = '0';
      }

      // Pick new quote each time we scroll down from top
      if (justScrolledDown) {
        techQuote.textContent = getRandomQuote();
      }

      lastScrollTop = scrollTop;
      ticking = false;
    }

    // Throttled scroll handler
    function requestTick() {
      if (!ticking) {
        window.requestAnimationFrame(updateHeaderState);
        ticking = true;
      }
    }

    // Attach scroll listener
    window.addEventListener('scroll', requestTick, { passive: true });

    // Initial state
    updateHeaderState();
  }

  // Avatar hover peek and wobble effect
  function initAvatarHoverEffect() {
    const avatarContainer = document.getElementById('avatar-container');
    const avatarLogo = document.getElementById('avatar-logo');
    const speechBubble = document.getElementById('speech-bubble');

    if (!avatarContainer || !avatarLogo || !speechBubble) {
      return;
    }

    let hoverTimeout = null;
    let speechTimeout = null;
    let hideTimeout = null;
    let isAnimating = false;

    function startAnimation() {
      if (isAnimating) return;

      // Clear any pending hide timeout
      if (hideTimeout) {
        clearTimeout(hideTimeout);
        hideTimeout = null;
      }

      hoverTimeout = setTimeout(() => {
        isAnimating = true;
        avatarLogo.classList.add('peeking');

        // Show speech bubble after avatar grows (0.4s into the animation)
        speechTimeout = setTimeout(() => {
          speechBubble.classList.add('show');
        }, 400);

        // No auto-hide - stays open until mouseleave/touchend
      }, 1000);
    }

    function stopAnimation() {
      if (hoverTimeout) {
        clearTimeout(hoverTimeout);
        hoverTimeout = null;
      }
      if (speechTimeout) {
        clearTimeout(speechTimeout);
        speechTimeout = null;
      }
      if (hideTimeout) {
        clearTimeout(hideTimeout);
        hideTimeout = null;
      }

      // Remove animation classes and reset
      avatarLogo.classList.remove('peeking');
      speechBubble.classList.remove('show');
      isAnimating = false;

      // Only reset if not currently scrolled (preserve scroll rotation)
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollTop <= 50) {
        avatarLogo.style.transform = 'rotate(0deg)';
      }
    }

    // Mouse events for desktop
    avatarContainer.addEventListener('mouseenter', startAnimation);
    avatarContainer.addEventListener('mouseleave', stopAnimation);

    // Touch events for mobile
    avatarContainer.addEventListener('touchstart', (e) => {
      e.preventDefault(); // Prevent mouse events from firing
      startAnimation();
    }, { passive: false });

    avatarContainer.addEventListener('touchend', () => {
      stopAnimation();
    });
  }

  // Mobile: click anywhere on header to scroll to top
  function initMobileScrollToTop() {
    if (window.innerWidth >= 768) {
      return; // Desktop only
    }

    const header = document.getElementById('liquid-header');
    if (!header) return;

    header.style.cursor = 'pointer';

    header.addEventListener('click', (e) => {
      // Don't trigger if clicking on a link
      if (e.target.tagName === 'A' || e.target.closest('a')) {
        return;
      }

      // Smooth scroll to top
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', () => {
    initHeaderScrollEffect();
    initAvatarHoverEffect();
    initMobileScrollToTop();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initHeaderScrollEffect();
      initAvatarHoverEffect();
      initMobileScrollToTop();
    });
  } else {
    initHeaderScrollEffect();
    initAvatarHoverEffect();
    initMobileScrollToTop();
  }
</script>
