---
interface Props {
  style: 'solid' | 'brands' | 'regular';
  icon: string;
  fw?: boolean;
  class?: string;
}

const { style, icon, fw = false, class: className = '' } = Astro.props;

// Simple FontAwesome icon component using CDN
const stylePrefix = style === 'solid' ? 'fas' : style === 'brands' ? 'fab' : 'far';
const classes = ['fa-icon', className, fw ? 'fa-fw' : ''].filter(Boolean).join(' ');
---

<i class={`${stylePrefix} fa-${icon} ${classes}`}></i>

<script is:inline>
  // Load FontAwesome from CDN if not already loaded
  if (!document.querySelector('link[href*="font-awesome"]')) {
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css';
    link.integrity = 'sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==';
    link.crossOrigin = 'anonymous';
    document.head.appendChild(link);
  }
</script>
