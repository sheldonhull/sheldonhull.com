---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sheldon Hull - Software Engineer" description="Software Engineer specializing in Go, DevOps, and Cloud Technologies">
  <div class="max-w-5xl mx-auto">
    <!-- Hero Section -->
    <div class="mb-20">
      <div class="mb-8">
        <h1 class="text-6xl font-bold mb-6 tracking-tight synthwave-gradient neon-glow-header-cyan">
          Sheldon Hull
        </h1>
        <p class="text-2xl mb-4 font-light" style="color: var(--sw-pink);">
          Software Engineer
        </p>
        <p class="text-lg max-w-2xl leading-relaxed" style="color: var(--sw-text-secondary);">
          Building reliable systems with Go. Focused on DevOps practices, cloud infrastructure, and developer tooling.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex gap-4 flex-wrap">
        <a
          href="/posts"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition-all hover:scale-105"
          style="background: var(--sw-pink); color: var(--sw-bg-primary); font-weight: 600;"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          Read Posts
        </a>
        <a
          href="https://github.com/sheldonhull"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition-all hover:scale-105 border"
          style="background: var(--sw-bg-tertiary); color: var(--sw-cyan); border-color: var(--sw-cyan);"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg transition-all hover:scale-105 border"
          style="background: var(--sw-bg-tertiary); color: var(--sw-purple); border-color: var(--sw-purple);"
        >
          About
        </a>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="mb-20">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--sw-cyan);">Current Focus</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-lg border transition-colors hover:border-[var(--sw-cyan)]" style="background: var(--sw-bg-secondary); border-color: rgba(127, 219, 202, 0.3);">
          <div class="mb-3" style="color: var(--sw-cyan);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2" style="color: var(--sw-text-primary);">Go Development</h3>
          <p class="text-sm" style="color: var(--sw-text-secondary);">
            Building robust backend services, CLI tools, and automation with Go's simplicity and performance.
          </p>
        </div>

        <div class="p-6 rounded-lg border transition-colors hover:border-[var(--sw-purple)]" style="background: var(--sw-bg-secondary); border-color: rgba(199, 146, 234, 0.3);">
          <div class="mb-3" style="color: var(--sw-purple);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2" style="color: var(--sw-text-primary);">DevOps & Infrastructure</h3>
          <p class="text-sm" style="color: var(--sw-text-secondary);">
            Automating deployments, managing cloud infrastructure, and improving developer workflows.
          </p>
        </div>

        <div class="p-6 rounded-lg border transition-colors hover:border-[var(--sw-pink)]" style="background: var(--sw-bg-secondary); border-color: rgba(255, 88, 116, 0.3);">
          <div class="mb-3" style="color: var(--sw-pink);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2" style="color: var(--sw-text-primary);">Cloud Technologies</h3>
          <p class="text-sm" style="color: var(--sw-text-secondary);">
            Designing scalable cloud solutions with AWS, infrastructure as code, and serverless architectures.
          </p>
        </div>
      </div>
    </div>

    <!-- Writing Section -->
    <div class="p-8 rounded-lg border transition-colors hover:border-[var(--sw-pink)]" style="background: var(--sw-bg-secondary); border-color: rgba(255, 88, 116, 0.3);">
      <div class="flex items-start gap-6">
        <div class="mt-1" style="color: var(--sw-pink);">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold mb-3" style="color: var(--sw-pink);">Technical Writing</h2>
          <p class="mb-4 leading-relaxed" style="color: var(--sw-text-secondary);">
            I write about software engineering, development practices, and lessons learned building systems.
            Topics range from Go programming and DevOps tooling to cloud infrastructure and productivity.
          </p>
          <a
            href="/posts"
            class="inline-flex items-center gap-2 font-medium transition-colors hover:opacity-80"
            style="color: var(--sw-pink);"
          >
            Browse all posts
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
