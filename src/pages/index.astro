---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sheldon Hull - Software Engineer" description="Software Engineer specializing in Go, DevOps, and Cloud Technologies">
  <div class="creative-home">
    <!-- Name Hero with Avatar -->
    <div class="name-section">
      <div class="name-with-avatar">
        <img
          src="/avatar-skitch-sheldon.png"
          alt="Sheldon Hull Avatar"
          class="hero-avatar"
        />
        <h1 class="mega-name">Greetings <br>& Salutations!</h1>
      </div>
    </div>

    <!-- Creative Typography Narrative -->
    <div class="narrative-section">
      <p class="creative-intro">
        Right now I'm exploring <span class="keyword keyword-agentic">agentic coding</span>,
        improving <span class="keyword keyword-devex">DevEx</span> for development teams,
        having my brain <span class="keyword keyword-melt">melt</span> as my son reminds me
        of all I've forgotten of <span class="keyword keyword-algebra">college algebra</span>,
        and <span class="keyword keyword-modernize">modernizing</span> this very site.
      </p>
    </div>

    <!-- Action Links -->
    <div class="action-links">
      <a
        href="/posts"
        class="action-btn btn-posts"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Read Posts
      </a>
      <a
        href="https://github.com/sheldonhull"
        target="_blank"
        rel="noopener noreferrer"
        class="action-btn btn-github"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a
        href="/about"
        class="action-btn btn-about"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        About
      </a>
    </div>

    <!-- Accent Tagline -->
    <div class="tagline-section">
      <p class="tagline">
        Making <span class="tagline-word">infrastructure</span>
        <span class="tagline-word-alt">dance</span> since
        <span class="tagline-highlight">2015</span>
      </p>
    </div>
  </div>

  <style>
    .creative-home {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      min-height: 80vh;
      position: relative;
    }

    /* Mega Name Section */
    .name-section {
      margin-bottom: 4rem;
      position: relative;
    }

    .name-with-avatar {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .hero-avatar {
      width: clamp(8rem, 15vw, 14rem);
      height: clamp(8rem, 15vw, 14rem);
      border-radius: 50%;
      border: 4px solid var(--sw-cyan);
      box-shadow:
        0 0 30px rgba(127, 219, 202, 0.4),
        0 0 60px rgba(199, 146, 234, 0.2);
      animation: avatarPulse 4s ease-in-out infinite;
      flex-shrink: 0;
    }

    @keyframes avatarPulse {
      0%, 100% {
        box-shadow:
          0 0 30px rgba(127, 219, 202, 0.4),
          0 0 60px rgba(199, 146, 234, 0.2);
        transform: scale(1);
      }
      50% {
        box-shadow:
          0 0 40px rgba(255, 88, 116, 0.5),
          0 0 80px rgba(127, 219, 202, 0.3);
        transform: scale(1.02);
      }
    }

    .mega-name {
      font-size: clamp(2.5rem, 10vw, 7rem);
      font-weight: 900;
      line-height: 0.9;
      margin: 0;
      letter-spacing: -0.05em;
      background: linear-gradient(
        135deg,
        var(--sw-cyan) 0%,
        var(--sw-purple) 35%,
        var(--sw-pink) 70%,
        var(--sw-yellow) 100%
      );
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: none;
      position: relative;
      animation: megaGlow 4s ease-in-out infinite;
      filter: drop-shadow(0 0 40px rgba(127, 219, 202, 0.3));
    }

    @keyframes megaGlow {
      0%, 100% {
        filter: drop-shadow(0 0 40px rgba(127, 219, 202, 0.3))
                drop-shadow(0 0 20px rgba(199, 146, 234, 0.2));
      }
      50% {
        filter: drop-shadow(0 0 50px rgba(255, 88, 116, 0.4))
                drop-shadow(0 0 30px rgba(127, 219, 202, 0.3));
      }
    }

    /* Narrative Section */
    .narrative-section {
      margin: 6rem 0;
      position: relative;
    }

    .creative-intro {
      font-size: clamp(1.75rem, 4vw, 3.5rem);
      line-height: 1.3;
      font-weight: 700;
      margin-bottom: 3rem;
      color: var(--sw-text-primary);
      letter-spacing: -0.02em;
    }

    .creative-body {
      font-size: clamp(1.25rem, 3vw, 2.25rem);
      line-height: 1.4;
      font-weight: 500;
      margin-bottom: 2.5rem;
      color: var(--sw-text-secondary);
      letter-spacing: -0.01em;
    }

    .accent-line {
      margin-top: 4rem;
      font-weight: 400;
      opacity: 0.95;
    }

    /* Keyword Highlights */
    .keyword {
      position: relative;
      font-weight: 800;
      letter-spacing: -0.02em;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: inline-block;
      padding: 0 0.15em;
      cursor: default;
    }

    .keyword-craft {
      color: var(--sw-cyan);
      text-shadow: 0 0 20px rgba(127, 219, 202, 0.6);
    }

    .keyword-go {
      color: var(--sw-blue);
      text-shadow: 0 0 20px rgba(130, 170, 255, 0.6);
      font-size: 1.15em;
    }

    .keyword-automate {
      color: var(--sw-purple);
      text-shadow: 0 0 20px rgba(199, 146, 234, 0.6);
    }

    .keyword-build {
      color: var(--sw-pink);
      text-shadow: 0 0 20px rgba(255, 88, 116, 0.6);
    }

    .keyword-devs {
      color: var(--sw-yellow);
      text-shadow: 0 0 20px rgba(236, 196, 141, 0.6);
    }

    .keyword-code {
      color: var(--sw-cyan);
      text-shadow: 0 0 15px rgba(127, 219, 202, 0.5);
    }

    .keyword-cloud {
      color: var(--sw-blue);
      text-shadow: 0 0 15px rgba(130, 170, 255, 0.5);
      font-style: italic;
    }

    .keyword-chaos {
      color: var(--sw-pink);
      text-shadow: 0 0 15px rgba(255, 88, 116, 0.5);
      font-style: italic;
    }

    .keyword-clarity {
      color: var(--sw-cyan);
      text-shadow: 0 0 15px rgba(127, 219, 202, 0.5);
      font-style: italic;
    }

    .keyword-deploy {
      color: var(--sw-purple);
      text-shadow: 0 0 15px rgba(199, 146, 234, 0.5);
    }

    .keyword-writing {
      color: var(--sw-pink);
      text-shadow: 0 0 15px rgba(255, 88, 116, 0.5);
    }

    .keyword-devops,
    .keyword-terraform,
    .keyword-k8s {
      color: var(--sw-cyan);
      text-shadow: 0 0 15px rgba(127, 219, 202, 0.5);
      font-family: 'Fira Code', monospace;
      font-size: 0.95em;
    }

    .keyword-new {
      color: var(--sw-yellow);
      text-shadow: 0 0 15px rgba(236, 196, 141, 0.5);
    }

    .keyword-optimize {
      color: var(--sw-purple);
      text-shadow: 0 0 15px rgba(199, 146, 234, 0.5);
    }

    .keyword-learned {
      color: var(--sw-cyan);
      text-shadow: 0 0 15px rgba(127, 219, 202, 0.5);
    }

    .keyword-agentic {
      color: var(--sw-purple);
      text-shadow: 0 0 20px rgba(199, 146, 234, 0.6);
      font-style: italic;
    }

    .keyword-devex {
      color: var(--sw-cyan);
      text-shadow: 0 0 20px rgba(127, 219, 202, 0.6);
      font-weight: 900;
    }

    .keyword-melt {
      color: var(--sw-pink);
      text-shadow: 0 0 20px rgba(255, 88, 116, 0.6);
      font-style: italic;
    }

    .keyword-algebra {
      color: var(--sw-yellow);
      text-shadow: 0 0 20px rgba(236, 196, 141, 0.6);
      font-family: 'Georgia', serif;
    }

    .keyword-modernize {
      color: var(--sw-blue);
      text-shadow: 0 0 20px rgba(130, 170, 255, 0.6);
    }

    /* Hover effects for keywords */
    .keyword:hover {
      transform: translateY(-2px) scale(1.05);
      filter: brightness(1.3);
    }

    .keyword::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: currentColor;
      transform: scaleX(0);
      transition: transform 0.3s ease;
      opacity: 0.5;
    }

    .keyword:hover::after {
      transform: scaleX(1);
    }

    /* Action Links */
    .action-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin: 4rem 0;
    }

    .action-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      border: 2px solid;
    }

    .btn-posts {
      background: var(--sw-pink);
      color: var(--sw-bg-primary);
      border-color: var(--sw-pink);
      box-shadow: 0 0 20px rgba(255, 88, 116, 0.3);
    }

    .btn-posts:hover {
      transform: scale(1.05);
      box-shadow: 0 0 30px rgba(255, 88, 116, 0.5);
      background: rgba(255, 88, 116, 0.9);
    }

    .btn-github {
      background: var(--sw-bg-tertiary);
      color: var(--sw-cyan);
      border-color: var(--sw-cyan);
      box-shadow: 0 0 20px rgba(127, 219, 202, 0.2);
    }

    .btn-github:hover {
      transform: scale(1.05);
      box-shadow: 0 0 30px rgba(127, 219, 202, 0.4);
      background: rgba(127, 219, 202, 0.1);
    }

    .btn-about {
      background: var(--sw-bg-tertiary);
      color: var(--sw-purple);
      border-color: var(--sw-purple);
      box-shadow: 0 0 20px rgba(199, 146, 234, 0.2);
    }

    .btn-about:hover {
      transform: scale(1.05);
      box-shadow: 0 0 30px rgba(199, 146, 234, 0.4);
      background: rgba(199, 146, 234, 0.1);
    }

    /* Tagline Section */
    .tagline-section {
      margin-top: 8rem;
      text-align: center;
      opacity: 0.8;
    }

    .tagline {
      font-size: clamp(1.5rem, 3vw, 2.5rem);
      font-weight: 600;
      color: var(--sw-text-secondary);
      letter-spacing: -0.02em;
    }

    .tagline-word {
      color: var(--sw-purple);
      font-style: italic;
      font-weight: 700;
    }

    .tagline-word-alt {
      color: var(--sw-pink);
      font-weight: 700;
      text-decoration: underline;
      text-decoration-color: rgba(255, 88, 116, 0.3);
      text-decoration-thickness: 3px;
      text-underline-offset: 0.2em;
    }

    .tagline-highlight {
      color: var(--sw-cyan);
      font-weight: 800;
      text-shadow: 0 0 20px rgba(127, 219, 202, 0.5);
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .creative-home {
        padding: 1.5rem;
      }

      .name-with-avatar {
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .hero-avatar {
        width: 6rem;
        height: 6rem;
      }

      .narrative-section {
        margin: 4rem 0;
      }

      .action-links {
        flex-direction: column;
        gap: 0.75rem;
        margin: 3rem 0;
      }

      .action-btn {
        width: 100%;
        justify-content: center;
      }

      .tagline-section {
        margin-top: 4rem;
      }
    }
  </style>

</BaseLayout>
