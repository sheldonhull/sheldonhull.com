---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';
---

<BaseLayout
  title="Portfolio - Sheldon Hull"
  description="The journey of a developer who loves Go, distributed systems, and tacos"
>
  <div class="max-w-5xl mx-auto">

    <!-- Hero Section -->
    <section class="mb-20 text-center">
      <h1 class="text-5xl font-bold mb-6 synthwave-gradient">
        Building Systems That Scale
      </h1>
      <p class="text-xl mb-8" style="color: var(--sw-text-secondary);">
        Staff Engineer focused on Go, distributed systems, and developer experience
      </p>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mt-12">
        <div class="stat-card">
          <div class="stat-icon-circle cyan">
            <FAIcon style="solid" icon="code" />
          </div>
          <div class="stat-number neon-glow-cyan" style="color: var(--sw-cyan);">13+</div>
          <div class="stat-label">Years Coding</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-circle purple">
            <FAIcon style="solid" icon="pepper-hot" />
          </div>
          <div class="stat-number neon-glow-purple" style="color: var(--sw-purple);">∞</div>
          <div class="stat-label">Tacos Consumed</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-circle pink">
            <FAIcon style="solid" icon="rss" />
          </div>
          <div class="stat-number neon-glow-pink" style="color: var(--sw-pink);">100+</div>
          <div class="stat-label">Blog Posts</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-circle cyan">
            <FAIcon style="brands" icon="golang" />
          </div>
          <div class="stat-label-large neon-glow-cyan" style="color: var(--sw-cyan);">Go</div>
          <div class="stat-label">Favorite Language</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-circle purple">
            <FAIcon style="solid" icon="wand-magic-sparkles" />
          </div>
          <div class="stat-label-large neon-glow-purple" style="color: var(--sw-purple);">Claude, Copilot, OpenCode</div>
          <div class="stat-label">Favorite AI Tools</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-circle yellow">
            <FAIcon style="solid" icon="moon" />
          </div>
          <div class="stat-label-large neon-glow-yellow" style="color: var(--sw-yellow);">Night Owl</div>
          <div class="stat-label">Favorite Theme</div>
        </div>
      </div>
    </section>

    <!-- The Journey Timeline -->
    <section class="mb-20">
      <h2 class="text-3xl font-bold mb-12 text-center neon-glow-purple" style="color: var(--sw-purple);">
        The Journey
      </h2>

      <div class="timeline">
        <!-- Staff Engineer @ Delinea -->
        <div class="timeline-item" data-era="go">
          <div class="timeline-marker" style="background: var(--sw-cyan);"></div>
          <div class="timeline-content">
            <div class="timeline-date" style="color: var(--sw-cyan);">2024 - Present</div>
            <h3 class="text-2xl font-bold mb-2" style="color: var(--sw-cyan);">Staff Software Engineer</h3>
            <div class="text-lg mb-3" style="color: var(--sw-text-secondary);">Delinea - Developer Experience Team</div>
            <p class="mb-4" style="color: var(--sw-text-secondary);">
              Promoted to Staff. Leading developer experience initiatives at scale.
              Making developers' lives better through better tooling, docs, and automation.
            </p>
            <details class="timeline-details">
              <summary style="color: var(--sw-cyan); cursor: pointer;">View highlights →</summary>
              <ul class="mt-4 space-y-2" style="color: var(--sw-text-secondary);">
                <li>⚡ Consolidated scattered docs into cohesive devex site</li>
                <li>⚡ Improved supply chain security tooling & guidance</li>
                <li>⚡ Cross-team impact with presentations & knowledge sharing</li>
                <li>⚡ Promoted for stellar performance & impact</li>
              </ul>
            </details>
          </div>
        </div>

        <!-- Senior Engineer @ Delinea -->
        <div class="timeline-item" data-era="go">
          <div class="timeline-marker" style="background: var(--sw-purple);"></div>
          <div class="timeline-content">
            <div class="timeline-date" style="color: var(--sw-purple);">2021 - 2024</div>
            <h3 class="text-2xl font-bold mb-2" style="color: var(--sw-purple);">Senior Software Engineer</h3>
            <div class="text-lg mb-3" style="color: var(--sw-text-secondary);">Delinea - AWS/Go Team</div>
            <p class="mb-4" style="color: var(--sw-text-secondary);">
              The Go era begins. Built Kubernetes stacks, led monorepo migration, and leveled up the entire SDLC.
            </p>
            <details class="timeline-details">
              <summary style="color: var(--sw-purple); cursor: pointer;">View highlights →</summary>
              <ul class="mt-4 space-y-2" style="color: var(--sw-text-secondary);">
                <li>🚀 Built Helm + Pulumi stack for K8s with &lt;15min PR-to-prod</li>
                <li>🔧 Wrote Go task automation for entire dev workflow (one command bootstrap)</li>
                <li>📦 Led monorepo migration for Angular + Go teams</li>
                <li>☁️ AWS architecture redesign for ECS Fargate</li>
                <li>📊 APM integration, structured logging, synthetic monitoring</li>
                <li>🎯 Trunk-based development & infrastructure-as-code adoption</li>
              </ul>
            </details>
          </div>
        </div>

        <!-- DevOps/SRE Era -->
        <div class="timeline-item" data-era="devops">
          <div class="timeline-marker" style="background: var(--sw-pink);"></div>
          <div class="timeline-content">
            <div class="timeline-date" style="color: var(--sw-pink);">2014 - 2021</div>
            <h3 class="text-2xl font-bold mb-2" style="color: var(--sw-pink);">Senior Developer / SRE</h3>
            <div class="text-lg mb-3" style="color: var(--sw-text-secondary);">Altus Group - Database & DevOps</div>
            <p class="mb-4" style="color: var(--sw-text-secondary);">
              Transformation years: SQL expert → DevOps practitioner → SRE. Built the automation, observability, and GitOps practices.
            </p>
            <details class="timeline-details">
              <summary style="color: var(--sw-pink); cursor: pointer;">View highlights →</summary>
              <ul class="mt-4 space-y-2" style="color: var(--sw-text-secondary);">
                <li>☁️ Part of on-premise → AWS cloud transformation</li>
                <li>🏗️ Designed serverless Lambda solutions for KPI insights</li>
                <li>📚 Built comprehensive runbook library (GitLab handbook-first inspired)</li>
                <li>🤖 Built systems management for hundreds of instances</li>
                <li>🎯 AMI pipelines with Packer, matrix builds, automated tests</li>
                <li>📊 Championed observability with Datadog, Grafana, InfluxDB</li>
                <li>🗄️ Database performance tuning & architectural design</li>
              </ul>
            </details>
          </div>
        </div>

        <!-- SQL Era -->
        <div class="timeline-item" data-era="sql">
          <div class="timeline-marker" style="background: var(--sw-yellow);"></div>
          <div class="timeline-content">
            <div class="timeline-date" style="color: var(--sw-yellow);">2011 - 2014</div>
            <h3 class="text-2xl font-bold mb-2" style="color: var(--sw-yellow);">SQL Server Developer</h3>
            <div class="text-lg mb-3" style="color: var(--sw-text-secondary);">Selene Finance</div>
            <p style="color: var(--sw-text-secondary);">
              Where it all began. Hired as Asset Analyst, taught myself SQL, got recruited to dev team.
              Relational database design, performance tuning, and learning to love code.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Arsenal -->
    <section class="mb-20">
      <h2 class="text-3xl font-bold mb-8 text-center neon-glow-cyan" style="color: var(--sw-cyan);">
        Tech Arsenal
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Mastered -->
        <div class="tech-category">
          <h3 class="text-xl font-bold mb-4 neon-glow-cyan" style="color: var(--sw-cyan);">
            Daily Weapons
          </h3>
          <div class="tech-tags">
            <span class="tech-tag cyan">Go</span>
            <span class="tech-tag cyan">Kubernetes</span>
            <span class="tech-tag cyan">Terraform</span>
            <span class="tech-tag cyan">Pulumi</span>
            <span class="tech-tag cyan">Docker</span>
            <span class="tech-tag cyan">GitHub Actions</span>
            <span class="tech-tag cyan">Datadog</span>
            <span class="tech-tag cyan">Linux</span>
            <span class="tech-tag cyan">PowerShell</span>
            <span class="tech-tag cyan">Technical Docs</span>
          </div>
        </div>

        <!-- Have Used -->
        <div class="tech-category">
          <h3 class="text-xl font-bold mb-4 neon-glow-purple" style="color: var(--sw-purple);">
            In The Toolbox
          </h3>
          <div class="tech-tags">
            <span class="tech-tag purple">AWS</span>
            <span class="tech-tag purple">Azure</span>
            <span class="tech-tag purple">RDBMS</span>
            <span class="tech-tag purple">Python</span>
            <span class="tech-tag purple">C# / .NET</span>
            <span class="tech-tag purple">Serverless</span>
            <span class="tech-tag purple">Azure Pipelines</span>
            <span class="tech-tag purple">Dagger</span>
          </div>
        </div>

        <!-- Want More -->
        <div class="tech-category">
          <h3 class="text-xl font-bold mb-4 neon-glow-pink" style="color: var(--sw-pink);">
            Want More Of
          </h3>
          <div class="tech-tags">
            <span class="tech-tag pink">AI</span>
            <span class="tech-tag pink">Agentic Workflows</span>
            <span class="tech-tag pink">Distributed Systems</span>
            <span class="tech-tag pink">Microservices</span>
            <span class="tech-tag pink">Service Mesh</span>
            <span class="tech-tag pink">Developer Tooling</span>
            <span class="tech-tag pink">Platform Engineering</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlight Reel -->
    <section class="mb-20">
      <h2 class="text-3xl font-bold mb-12 text-center neon-glow-pink" style="color: var(--sw-pink);">
        Impact Highlights
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- AI & Agentic Workflows -->
        <div class="highlight-card-substantial cyan">
          <div class="highlight-icon cyan">
            <FAIcon style="solid" icon="robot" />
          </div>
          <h3 class="text-2xl font-bold mb-3">AI: Agentic Workflows & Adoption</h3>
          <div class="highlight-metric">
            <span class="metric-number">Edge</span>
            <span class="metric-label">adopter & advocate</span>
          </div>
          <p class="mb-4" style="color: var(--sw-text-secondary);">
            <strong style="color: var(--sw-cyan);">Edge adopter</strong> and internal advocate for agentic coding workflows and AI-assisted development.
            Led education initiatives on agent automation, shared best practices across engineering,
            and assisted with Copilot and Claude administration for enterprise adoption.
          </p>
          <div class="tech-stack-mini">
            <span>Claude Code</span>
            <span>GitHub Copilot</span>
            <span>Agentic Workflows</span>
            <span>Internal Advocacy</span>
          </div>
          <div class="highlight-impact">
            <FAIcon style="solid" icon="rocket" />
            <span>Accelerating team velocity with AI</span>
          </div>
        </div>

        <!-- Automate The Boring Things -->
        <div class="highlight-card-substantial purple">
          <div class="highlight-icon purple">
            <FAIcon style="solid" icon="wand-magic-sparkles" />
          </div>
          <h3 class="text-2xl font-bold mb-3">Automate The Boring Things</h3>
          <div class="highlight-metric">
            <span class="metric-number">DevEx</span>
            <span class="metric-label">first mentality</span>
          </div>
          <p class="mb-4" style="color: var(--sw-text-secondary);">
            Built end-to-end developer experience improvements focusing on contributing ease and velocity.
            One-command bootstrap for tooling setup and first-class documentation.
          </p>
          <div class="tech-stack-mini">
            <span>Go/Mage</span>
            <span>Pre-commit</span>
            <span>Docs-as-Code</span>
            <span>GitHub Actions</span>
            <span>Monorepo</span>
          </div>
          <div class="highlight-impact">
            <FAIcon style="solid" icon="gauge-high" />
            <span>Eliminated days of manual setup toil</span>
          </div>
        </div>

        <!-- Supply Chain Security -->
        <div class="highlight-card-substantial pink">
          <div class="highlight-icon pink">
            <FAIcon style="solid" icon="shield-halved" />
          </div>
          <h3 class="text-2xl font-bold mb-3">Supply Chain Security</h3>
          <div class="highlight-metric">
            <span class="metric-number">Secure</span>
            <span class="metric-label">by default</span>
          </div>
          <p class="mb-4" style="color: var(--sw-text-secondary);">
            Established supply chain security practices and tooling guidance for growing engineering org.
            Integrated Snyk for SCA and SAST scanning, automated SBOM generation, and built security-first
            developer workflows with automated scanning in CI/CD pipelines.
          </p>
          <div class="tech-stack-mini">
            <span>Snyk</span>
            <span>SBOM</span>
            <span>SCA</span>
            <span>SAST</span>
            <span>GitHub Actions</span>
          </div>
          <div class="highlight-impact">
            <FAIcon style="solid" icon="lock" />
            <span>Security integrated into every commit</span>
          </div>
        </div>

        <!-- Build & Release Engineering -->
        <div class="highlight-card-substantial yellow">
          <div class="highlight-icon yellow">
            <FAIcon style="solid" icon="screwdriver-wrench" />
          </div>
          <h3 class="text-2xl font-bold mb-3">Backend Plumber: Build & Release</h3>
          <div class="highlight-metric">
            <span class="metric-number">&lt;15</span>
            <span class="metric-label">minutes to production</span>
          </div>
          <p class="mb-4" style="color: var(--sw-text-secondary);">
            Like a plumber fixing pipes you didn't know were leaking. Architected Kubernetes deployment
            pipelines with Helm + Pulumi achieving sub-15-minute PR-to-prod. Built robust AMI pipelines with
            Packer, matrix builds, and automated tests. GitHub admin work ensuring the pipes stay clear.
          </p>
          <div class="tech-stack-mini">
            <span>Azure Pipelines</span>
            <span>GitHub Actions</span>
            <span>Dagger SDK</span>
            <span>Helm</span>
            <span>Packer</span>
          </div>
          <div class="highlight-impact">
            <FAIcon style="solid" icon="bolt" />
            <span>10x deployment velocity improvement</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Culture Fit -->
    <section class="mb-20">
      <h2 class="text-3xl font-bold mb-8 text-center neon-glow-purple" style="color: var(--sw-purple);">
        What Makes Me Tick
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="culture-card">
          <h3 class="text-xl font-bold mb-4 neon-glow-cyan flex items-center gap-2" style="color: var(--sw-cyan);">
            <FAIcon style="solid" icon="star" />
            My Strengths
          </h3>
          <ul class="space-y-3" style="color: var(--sw-text-secondary);">
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="comment" class="mt-1 flex-shrink-0" style="color: var(--sw-cyan);" />
              <span>Emotional intelligence & influence-based leadership</span>
            </li>
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="check-circle" class="mt-1 flex-shrink-0" style="color: var(--sw-cyan);" />
              <span>"Cradle to grave" ownership mentality</span>
            </li>
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="book" class="mt-1 flex-shrink-0" style="color: var(--sw-cyan);" />
              <span>Documentation obsessive (handbook-first approach)</span>
            </li>
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="tachometer-alt" class="mt-1 flex-shrink-0" style="color: var(--sw-cyan);" />
              <span>Balance craft with shipping fast</span>
            </li>
          </ul>
        </div>

        <div class="culture-card">
          <h3 class="text-xl font-bold mb-4 neon-glow-pink flex items-center gap-2" style="color: var(--sw-pink);">
            <FAIcon style="solid" icon="heart" />
            I Thrive In
          </h3>
          <ul class="space-y-3" style="color: var(--sw-text-secondary);">
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="laptop" class="mt-1 flex-shrink-0" style="color: var(--sw-pink);" />
              <span>Remote-first, async communication cultures</span>
            </li>
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="users" class="mt-1 flex-shrink-0" style="color: var(--sw-pink);" />
              <span>Teams that value generalists with deep expertise</span>
            </li>
            <li class="flex items-start gap-2">
              <FAIcon style="solid" icon="rocket" class="mt-1 flex-shrink-0" style="color: var(--sw-pink);" />
              <span>Places that ship fast but care about reliability</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Connect -->
    <section class="text-center mb-20">
      <h2 class="text-3xl font-bold mb-8 neon-glow-cyan" style="color: var(--sw-cyan);">
        Let's Connect
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://github.com/sheldonhull" target="_blank" rel="noopener noreferrer" class="cta-button cyan">
          GitHub
        </a>
        <a href="https://www.sheldonhull.com/tags/golang" target="_blank" rel="noopener noreferrer" class="cta-button purple">
          Blog
        </a>
        <a href="https://github.com/sheldonhull/sheldonhull.hugo/discussions/new?category=ama" target="_blank" rel="noopener noreferrer" class="cta-button pink">
          Ask Me Anything
        </a>
      </div>
      <p class="mt-8 text-sm" style="color: var(--sw-text-muted);">
        Not a recruiter? Even better. Let's talk tech.
      </p>
    </section>

  </div>
</BaseLayout>

<style>
  /* Stats Cards */
  .stat-card {
    padding: 1.5rem;
    border-radius: 0.75rem;
    background: var(--sw-bg-secondary);
    border: 1px solid rgba(127, 219, 202, 0.2);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(127, 219, 202, 0.5);
    box-shadow: 0 8px 24px rgba(127, 219, 202, 0.2);
  }

  .stat-icon-circle {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    transition: all 0.3s ease;
  }

  .stat-icon-circle.cyan {
    background: rgba(127, 219, 202, 0.15);
    color: var(--sw-cyan);
    box-shadow: 0 0 16px rgba(127, 219, 202, 0.3);
  }

  .stat-card:hover .stat-icon-circle.cyan {
    background: rgba(127, 219, 202, 0.25);
    box-shadow: 0 0 24px rgba(127, 219, 202, 0.5);
    transform: scale(1.1) rotate(5deg);
  }

  .stat-icon-circle.purple {
    background: rgba(199, 146, 234, 0.15);
    color: var(--sw-purple);
    box-shadow: 0 0 16px rgba(199, 146, 234, 0.3);
  }

  .stat-card:hover .stat-icon-circle.purple {
    background: rgba(199, 146, 234, 0.25);
    box-shadow: 0 0 24px rgba(199, 146, 234, 0.5);
    transform: scale(1.1) rotate(5deg);
  }

  .stat-icon-circle.pink {
    background: rgba(255, 88, 116, 0.15);
    color: var(--sw-pink);
    box-shadow: 0 0 16px rgba(255, 88, 116, 0.3);
  }

  .stat-card:hover .stat-icon-circle.pink {
    background: rgba(255, 88, 116, 0.25);
    box-shadow: 0 0 24px rgba(255, 88, 116, 0.5);
    transform: scale(1.1) rotate(5deg);
  }

  .stat-icon-circle.yellow {
    background: rgba(236, 196, 141, 0.15);
    color: var(--sw-yellow);
    box-shadow: 0 0 16px rgba(236, 196, 141, 0.3);
  }

  .stat-card:hover .stat-icon-circle.yellow {
    background: rgba(236, 196, 141, 0.25);
    box-shadow: 0 0 24px rgba(236, 196, 141, 0.5);
    transform: scale(1.1) rotate(5deg);
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-label-large {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--sw-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--sw-cyan) 0%,
      var(--sw-purple) 33%,
      var(--sw-pink) 66%,
      var(--sw-yellow) 100%
    );
    opacity: 0.3;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
    padding-left: 2rem;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    box-shadow: 0 0 12px currentColor;
    transform: translateX(-50%);
  }

  .timeline-content {
    background: var(--sw-bg-secondary);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(127, 219, 202, 0.2);
    transition: all 0.3s ease;
  }

  .timeline-content:hover {
    border-color: rgba(127, 219, 202, 0.5);
    box-shadow: 0 4px 16px rgba(127, 219, 202, 0.15);
  }

  .timeline-date {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-details summary {
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .timeline-details summary:hover {
    text-shadow: 0 0 8px currentColor;
  }

  .timeline-details ul {
    list-style: none;
    padding-left: 0;
  }

  /* Tech Tags */
  .tech-category {
    background: var(--sw-bg-secondary);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(127, 219, 202, 0.2);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.3s ease;
    cursor: default;
  }

  .tech-tag.cyan {
    background: rgba(127, 219, 202, 0.1);
    border: 1px solid rgba(127, 219, 202, 0.3);
    color: var(--sw-cyan);
  }

  .tech-tag.cyan:hover {
    background: rgba(127, 219, 202, 0.2);
