      {
        title: 'GPT Diagnostics Pro',
        description: 'Started using ChatGPT for troubleshooting. Rubber duck debugging evolved to AI debugging.',
        icon: 'robot',
        iconStyle: 'solid',
        xp: 50,
        attributes: [
          { name: 'AI', value: 2 },
          { name: 'Problem Solving', value: 2 },
          { name: 'Googling', value: -1 }
        ]
      }
    ]
  },
  {
    year: 2025,
    level: 12,
    title: 'Modern Stack Embracer',
    subtitle: 'Hugo was so 2023',
    achievements: [
      {
        title: 'Astro Migration',
        description: 'Migrated entire site to Astro. Modern DX achieved. Component islands everywhere.',
        icon: 'rocket',
        iconStyle: 'solid',
        xp: 150,
        attributes: [
          { name: 'Frontend', value: 3 },
          { name: 'Modern JS', value: 2 },
          { name: 'Static Site Gen', value: 2 }
        ]
      }
    ]
  }
];

// Calculate cumulative stats
interface Stats {
  [key: string]: number;
}

function calculateCumulativeStats(upToLevel: number): Stats {
  const stats: Stats = {};

  for (let i = 0; i <= upToLevel && i < yearLevels.length; i++) {
    const level = yearLevels[i];
    level.achievements.forEach(achievement => {
      achievement.attributes.forEach(attr => {
        stats[attr.name] = (stats[attr.name] || 0) + attr.value;
      });
    });
  }

  return stats;
}

const totalXP = yearLevels.reduce((sum, level) =>
  sum + level.achievements.reduce((achSum, ach) => achSum + ach.xp, 0), 0
);

const finalStats = calculateCumulativeStats(yearLevels.length - 1);
---

<BaseLayout title="RPG Life Stats | Sheldon Hull" description="Life as an RPG adventure">
  <div class="rpg-container">
    <!-- Pixel Art Character - Improved and More Visible -->
    <div class="character-display">
      <div class="pixel-mage-large">
        <!-- Better pixel art character -->
        <svg viewBox="0 0 32 32" class="mage-sprite">
          <!-- Hood -->
          <rect x="10" y="4" width="12" height="2" fill="#6b46c1"/>
          <rect x="8" y="6" width="16" height="2" fill="#6b46c1"/>
          <rect x="7" y="8" width="18" height="2" fill="#7c3aed"/>

          <!-- Face -->
          <rect x="12" y="10" width="8" height="6" fill="#d4a574"/>
          <rect x="13" y="12" width="2" height="1" fill="#4a2511"/>
          <rect x="17" y="12" width="2" height="1" fill="#4a2511"/>

          <!-- Body/Robe -->
          <rect x="9" y="16" width="14" height="2" fill="#8b5cf6"/>
          <rect x="8" y="18" width="16" height="4" fill="#7c3aed"/>
          <rect x="7" y="22" width="18" height="4" fill="#6b21a8"/>
          <rect x="9" y="26" width="5" height="4" fill="#5b21b6"/>
          <rect x="18" y="26" width="5" height="4" fill="#5b21b6"/>

          <!-- Staff -->
          <rect x="26" y="14" width="2" height="14" fill="#92400e"/>
          <rect x="25" y="12" width="4" height="4" fill="#fbbf24" opacity="0.8"/>
          <circle cx="27" cy="14" r="2" fill="#fde047" opacity="0.9"/>

          <!-- Magic glow effect -->
          <circle cx="27" cy="14" r="3" fill="#fbbf24" opacity="0.3" class="staff-glow"/>
        </svg>
      </div>
      <div class="character-label">Level {yearLevels.length} Mage</div>
    </div>

    <!-- Stats Tracker -->
    <div class="stats-tracker" id="statsTracker">
      <div class="stats-header">
        <FAIcon style="solid" icon="chart-line" />
        <span>Current Stats</span>
      </div>
      <div class="stats-grid" id="statsGrid">
        <!-- Stats will be populated by JavaScript -->
      </div>
    </div>

    <!-- Horizontal scrolling card sections -->
    <div class="cards-wrapper" id="cardsWrapper">
      {yearLevels.map((level, index) => {
        const cumulativeStats = calculateCumulativeStats(index);

        return (
          <section class="card-section" data-level={level.level}>
            <div class="rpg-card">
              <div class="card-header">
                <div class="card-level">LEVEL {level.level}</div>
                <div class="card-year">{level.year}</div>
              </div>

              <div class="card-title-block">
                <h2 class="card-title">{level.title}</h2>
                <p class="card-subtitle">{level.subtitle}</p>
              </div>

              <div class="card-body">
                {level.achievements.map((achievement) => (
                  <div class="achievement-block">
                    <div class="achievement-header">
                      <div class="achievement-icon-circle">
                        <FAIcon style={achievement.iconStyle} icon={achievement.icon} />
                      </div>
                      <div class="achievement-title-wrap">
                        <h3 class="achievement-title">{achievement.title}</h3>
                        <span class="achievement-xp">+{achievement.xp} XP</span>
                      </div>
                    </div>

                    <p class="achievement-description">{achievement.description}</p>

                    <div class="attributes-list">
                      {achievement.attributes.map((attr) => (
                        <div class="attribute-tag" class:list={[attr.value < 0 && 'negative']}>
                          <span class="attr-name">{attr.name}</span>
                          <span class="attr-value">{attr.value > 0 ? '+' : ''}{attr.value}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>

              <div class="card-footer">
                <div class="footer-stat">
                  <FAIcon style="solid" icon="star" />
                  <span>{level.achievements.reduce((sum, a) => sum + a.xp, 0)} XP</span>
                </div>
              </div>
            </div>
          </section>
        );
      })}

      <!-- Final Stats Card -->
      <section class="card-section final-card">
        <div class="rpg-card">
          <div class="card-title-block">
            <h2 class="card-title">Journey Complete</h2>
            <p class="card-subtitle">For now...</p>
          </div>

          <div class="final-stats-display">
            <div class="final-stat-box">
              <FAIcon style="solid" icon="trophy" />
              <span class="final-stat-value">{yearLevels.length}</span>
              <span class="final-stat-label">Levels</span>
            </div>
            <div class="final-stat-box">
              <FAIcon style="solid" icon="star" />
              <span class="final-stat-value">{totalXP}</span>
              <span class="final-stat-label">Total XP</span>
            </div>
            <div class="final-stat-box">
              <FAIcon style="solid" icon="medal" />
              <span class="final-stat-value">{Object.keys(finalStats).length}</span>
              <span class="final-stat-label">Attributes</span>
            </div>
          </div>

          <div class="final-attributes">
            <h3 class="final-attributes-title">Final Attributes</h3>
            <div class="final-attributes-grid">
              {Object.entries(finalStats).sort((a, b) => b[1] - a[1]).map(([name, value]) => (
                <div class="final-attribute-item">
                  <span class="final-attr-name">{name}</span>
                  <span class="final-attr-value">{value > 0 ? '+' : ''}{value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Navigation -->
    <button class="nav-btn nav-prev" id="navPrev" aria-label="Previous level">
      <FAIcon style="solid" icon="chevron-left" />
    </button>
    <button class="nav-btn nav-next" id="navNext" aria-label="Next level">
      <FAIcon style="solid" icon="chevron-right" />
    </button>

    <!-- Progress dots -->
    <div class="progress-dots">
      {yearLevels.map((level, index) => (
        <button class="progress-dot" data-index={index} class:list={[{ active: index === 0 }]}>
          <span class="sr-only">Level {level.level}</span>
        </button>
      ))}
      <button class="progress-dot" data-index={yearLevels.length}>
        <span class="sr-only">Final Stats</span>
      </button>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ yearLevels }}>
  let currentSection = 0;
  const wrapper = document.getElementById('cardsWrapper');
  const sections = document.querySelectorAll('.card-section');
  const dots = document.querySelectorAll('.progress-dot');
  const navPrev = document.getElementById('navPrev');
  const navNext = document.getElementById('navNext');
  const statsGrid = document.getElementById('statsGrid');

  let isScrolling = false;
  let touchStartX = 0;

  function calculateCumulativeStats(upToIndex) {
    const stats = {};

    for (let i = 0; i <= upToIndex && i < yearLevels.length; i++) {
      const level = yearLevels[i];
      level.achievements.forEach(achievement => {
        achievement.attributes.forEach(attr => {
          stats[attr.name] = (stats[attr.name] || 0) + attr.value;
        });
      });
    }

    return stats;
  }

  function updateStatsDisplay(stats) {
    if (!statsGrid) return;

    const sortedStats = Object.entries(stats).sort((a, b) => Math.abs(b[1]) - Math.abs(a[1]));
    const topStats = sortedStats.slice(0, 6);

    statsGrid.innerHTML = topStats.map(([name, value]) => `
      <div class="stat-item ${value < 0 ? 'negative' : ''}">
        <span class="stat-name">${name}</span>
        <span class="stat-value">${value > 0 ? '+' : ''}${value}</span>
      </div>
    `).join('');
  }

  function updateSection(index) {
    if (index < 0 || index >= sections.length) return;

    currentSection = index;
    const scrollAmount = currentSection * window.innerWidth;

    wrapper?.scrollTo({
      left: scrollAmount,
      behavior: 'smooth'
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSection);
    });

    // Update stats display
    if (currentSection < yearLevels.length) {
      const stats = calculateCumulativeStats(currentSection);
      updateStatsDisplay(stats);
    }

    if (navPrev) navPrev.style.opacity = currentSection === 0 ? '0.3' : '1';
    if (navNext) navNext.style.opacity = currentSection === sections.length - 1 ? '0.3' : '1';
  }

  // Wheel scroll
  wrapper?.addEventListener('wheel', (e) => {
    e.preventDefault();
    if (isScrolling) return;

    isScrolling = true;
    setTimeout(() => isScrolling = false, 800);

    if (e.deltaY > 0 || e.deltaX > 0) {
      updateSection(currentSection + 1);
    } else if (e.deltaY < 0 || e.deltaX < 0) {
      updateSection(currentSection - 1);
    }
  }, { passive: false });

  // Touch support
  wrapper?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  });

  wrapper?.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      updateSection(currentSection + (diff > 0 ? 1 : -1));
    }
  });

  navPrev?.addEventListener('click', () => updateSection(currentSection - 1));
  navNext?.addEventListener('click', () => updateSection(currentSection + 1));

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => updateSection(index));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') updateSection(currentSection + 1);
    if (e.key === 'ArrowLeft') updateSection(currentSection - 1);
  });

  updateSection(0);
</script>

<style>
  .rpg-container {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(ellipse at top, rgba(123, 58, 237, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at bottom, rgba(16, 33, 62, 0.8) 0%, transparent 50%),
      linear-gradient(180deg, #0a0e27 0%, #1a1b26 100%);
  }

  /* Character Display - Improved */
  .character-display {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .pixel-mage-large {
    width: 128px;
    height: 128px;
    padding: 12px;
    background: rgba(16, 21, 38, 0.8);
    border: 3px solid rgba(139, 92, 246, 0.5);
    border-radius: 12px;
    box-shadow:
      0 0 30px rgba(139, 92, 246, 0.4),
      inset 0 0 20px rgba(139, 92, 246, 0.1);
    backdrop-filter: blur(10px);
  }

  .mage-sprite {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.6));
  }

  .staff-glow {
    animation: pulse 2s ease-in-out infinite;
  }

  .character-label {
    font-size: 12px;
    font-weight: 600;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    background: rgba(139, 92, 246, 0.2);
    border-radius: 8px;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  /* Stats Tracker */
  .stats-tracker {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 200;
    background: rgba(16, 21, 38, 0.9);
    border: 2px solid rgba(139, 92, 246, 0.4);
    border-radius: 12px;
    padding: 16px;
    min-width: 280px;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .stats-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 700;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(139, 92, 246, 0.3);
  }

  .stats-grid {
    display: grid;
    gap: 6px;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 10px;
    background: rgba(139, 92, 246, 0.1);
    border-radius: 6px;
    font-size: 13px;
  }

  .stat-item.negative {
    background: rgba(248, 113, 113, 0.1);
  }

  .stat-name {
    color: var(--sw-text-secondary);
    font-weight: 500;
  }

  .stat-value {
    color: #10b981;
    font-weight: 700;
    font-family: 'Monaco', monospace;
  }

  .stat-item.negative .stat-value {
    color: #f87171;
  }

  /* Cards Wrapper */
  .cards-wrapper {
    display: flex;
    height: 100vh;
    overflow-x: hidden;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }

  .card-section {
    min-width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    scroll-snap-align: start;
  }

  /* RPG Card Styling */
  .rpg-card {
    max-width: 700px;
    width: 100%;
    background:
      linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(16, 21, 38, 0.95) 100%);
    border: 3px solid;
    border-image: linear-gradient(135deg, #7c3aed, #6b21a8, #5b21b6) 1;
    border-radius: 16px;
    padding: 0;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(139, 92, 246, 0.2),
      inset 0 0 30px rgba(139, 92, 246, 0.05);
    animation: cardAppear 0.6s ease-out;
    position: relative;
    overflow: hidden;
  }

  .rpg-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
