---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';
import {
  yearLevels,
  calculateCumulativeStats,
  getTotalXP,
  getTotalAchievements,
  getFinalStats,
  getTopStats,
  type Stats
} from '../data/levelUpData';

const totalXP = getTotalXP();
const totalAchievements = getTotalAchievements();
const finalStats = getFinalStats();
---

<BaseLayout title="RPG Life Stats | Sheldon Hull" description="Life as an RPG adventure">
  <div class="rpg-container">
    <!-- Larger Animated Pixel Mage Sprite -->
    <div class="sprite-display">
      <div class="pixel-mage-large">
        <svg viewBox="0 0 32 32" class="mage-sprite" id="mageSprite">
          <!-- Hood -->
          <rect x="10" y="3" width="12" height="2" fill="#6b46c1"/>
          <rect x="8" y="5" width="16" height="2" fill="#6b46c1"/>
          <rect x="7" y="7" width="18" height="3" fill="#7c3aed"/>

          <!-- Face -->
          <rect x="12" y="10" width="8" height="6" fill="#d4a574"/>
          <rect x="13" y="12" width="2" height="1" fill="#4a2511" class="left-eye"/>
          <rect x="17" y="12" width="2" height="1" fill="#4a2511" class="right-eye"/>
          <rect x="14" y="14" width="4" height="1" fill="#c48b5c" opacity="0.6"/>

          <!-- Body/Robe -->
          <rect x="9" y="16" width="14" height="2" fill="#8b5cf6"/>
          <rect x="8" y="18" width="16" height="5" fill="#7c3aed"/>
          <rect x="7" y="23" width="18" height="4" fill="#6b21a8"/>

          <!-- Feet (for walking animation) -->
          <rect x="9" y="27" width="5" height="4" fill="#5b21b6" class="left-foot"/>
          <rect x="18" y="27" width="5" height="4" fill="#5b21b6" class="right-foot"/>

          <!-- Staff -->
          <rect x="26" y="14" width="2" height="15" fill="#92400e" class="staff"/>
          <rect x="25" y="12" width="4" height="4" fill="#fbbf24" opacity="0.8"/>
          <circle cx="27" cy="14" r="2.5" fill="#fde047" opacity="0.9" class="orb"/>

          <!-- Magic glow -->
          <circle cx="27" cy="14" r="3.5" fill="#fbbf24" opacity="0.3" class="glow"/>
        </svg>
      </div>
      <div class="sprite-label">Level {yearLevels.length} Mage</div>
    </div>

    <!-- Stats Panel (Left Side, Near Card) -->
    <div class="stats-panel" id="statsPanel">
      <div class="stats-header">
        <FAIcon style="solid" icon="chart-line" />
        <span>Stats</span>
      </div>
      <div class="stats-list" id="statsList">
        <!-- Will be populated by JS -->
      </div>
      <div class="stats-footer">
        <span class="xp-display" id="xpDisplay">0 XP</span>
      </div>
    </div>

    <!-- Card Stack Container -->
    <div class="card-stack-container">
      <div class="card-stack" id="cardStack">
        {yearLevels.map((level, index) => (
          <div
            class="card-wrapper"
            data-index={index}
            data-level={level.level}
            style={`z-index: ${yearLevels.length - index};`}
          >
            <div class="card-inner">
              {/* Front of card */}
              <div class="card-face card-front">
                <div class="card-portrait">
                  {/* Card Header */}
                  <div class="card-header-portrait">
                    <div class="card-level-badge">LVL {level.level}</div>
                    <div class="card-year-badge">{level.year}</div>
                  </div>

                  {/* Title Block */}
                  <div class="card-title-portrait">
                    <h2 class="portrait-title">{level.title}</h2>
                    <p class="portrait-subtitle">{level.subtitle}</p>
                  </div>

                  {/* Achievements in Portrait Layout */}
                  <div class="achievements-portrait">
                    {level.achievements.map((achievement) => (
                      <div class="achievement-entry">
                        <div class="achievement-icon-small">
                          <FAIcon style={achievement.iconStyle} icon={achievement.icon} />
                        </div>
                        <div class="achievement-details">
                          <h3 class="achievement-name">{achievement.title}</h3>
                          <p class="achievement-flavor">{achievement.description}</p>
                          <div class="achievement-stats">
                            <span class="xp-tag">+{achievement.xp} XP</span>
                            <div class="attrs-mini">
                              {achievement.attributes.slice(0, 3).map((attr) => (
                                <span class="attr-mini" class:list={[attr.value < 0 && 'neg']}>
                                  {attr.name} {attr.value > 0 ? '+' : ''}{attr.value}
                                </span>
                              ))}
                              {achievement.attributes.length > 3 && (
                                <span class="attr-mini more">+{achievement.attributes.length - 3} more</span>
                              )}
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>

                  {/* Card Footer */}
                  <div class="card-footer-portrait">
                    <div class="total-xp-badge">
                      <FAIcon style="solid" icon="star" />
                      {level.achievements.reduce((sum, a) => sum + a.xp, 0)} XP
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}

        {/* Final Stats Card */}
        <div
          class="card-wrapper final-card-wrapper"
          data-index={yearLevels.length}
          style={`z-index: 0;`}
        >
          <div class="card-inner">
            <div class="card-face card-front">
              <div class="card-portrait final-portrait">
                <div class="final-header">
                  <h2 class="final-title">Journey Complete</h2>
                  <p class="final-subtitle">For now...</p>
                </div>

                <div class="final-stats-grid">
                  <div class="final-stat">
                    <FAIcon style="solid" icon="trophy" />
                    <span class="final-value">{yearLevels.length}</span>
                    <span class="final-label">Levels</span>
                  </div>
                  <div class="final-stat">
                    <FAIcon style="solid" icon="star" />
                    <span class="final-value">{totalXP}</span>
                    <span class="final-label">Total XP</span>
                  </div>
                  <div class="final-stat">
                    <FAIcon style="solid" icon="award" />
                    <span class="final-value">{totalAchievements}</span>
                    <span class="final-label">Achievements</span>
                  </div>
                </div>

                <div class="final-attributes">
                  <h3 class="attrs-title">Final Attributes</h3>
                  <div class="attrs-final-list">
                    {Object.entries(finalStats)
                      .sort((a, b) => Math.abs(b[1]) - Math.abs(a[1]))
                      .map(([name, value]) => (
                        <div class="attr-final-item">
                          <span>{name}</span>
                          <span class:list={[value < 0 && 'neg']}>
                            {value > 0 ? '+' : ''}{value}
                          </span>
                        </div>
                      ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Navigation Controls -->
    <button class="nav-button nav-prev" id="navPrev" aria-label="Previous card">
      <FAIcon style="solid" icon="chevron-left" />
    </button>
    <button class="nav-button nav-next" id="navNext" aria-label="Next card">
      <FAIcon style="solid" icon="chevron-right" />
    </button>

    <!-- Progress Indicator -->
    <div class="progress-indicator">
      <span id="progressText">Level 1 / {yearLevels.length}</span>
    </div>
  </div>
</BaseLayout>

<script>
  import { yearLevels, calculateCumulativeStats, calculateTotalXP, getTopStats } from '../data/levelUpData';

  let currentIndex = 0;
  const totalCards = yearLevels.length + 1; // +1 for final card

  const cardStack = document.getElementById('cardStack');
  const cards = document.querySelectorAll('.card-wrapper');
  const navPrev = document.getElementById('navPrev');
  const navNext = document.getElementById('navNext');
  const statsPanel = document.getElementById('statsPanel');
  const statsList = document.getElementById('statsList');
  const xpDisplay = document.getElementById('xpDisplay');
  const progressText = document.getElementById('progressText');
  const mageSprite = document.getElementById('mageSprite');

  // Sprite animation variants
  const spriteAnimations = ['walk', 'scratch', 'shift', 'twirl'];
  let currentAnimation = '';

  function playRandomAnimation() {
    // Remove current animation
    if (currentAnimation) {
      mageSprite?.classList.remove(currentAnimation);
    }

    // Pick random animation
    const randomAnim = spriteAnimations[Math.floor(Math.random() * spriteAnimations.length)];
    currentAnimation = randomAnim;
    mageSprite?.classList.add(randomAnim);

    // Remove after animation completes
    setTimeout(() => {
      mageSprite?.classList.remove(randomAnim);
      currentAnimation = '';
    }, 800);
  }

  function updateStats(index: number) {
    if (index >= yearLevels.length) {
      // Final card - show all stats
      statsList!.innerHTML = '<div class="stat-item final-stats-note">Final Stats →</div>';
      xpDisplay!.textContent = `${calculateTotalXP(yearLevels.length - 1)} XP`;
      return;
    }

    const stats = calculateCumulativeStats(index);
    const xp = calculateTotalXP(index);
    const topStats = getTopStats(stats, 6);

    statsList!.innerHTML = topStats.map(([name, value]) => `
      <div class="stat-item ${value < 0 ? 'negative' : ''}">
        <span class="stat-name">${name}</span>
        <span class="stat-value">${value > 0 ? '+' : ''}${value}</span>
      </div>
    `).join('');

    xpDisplay!.textContent = `${xp} XP`;
  }

  function updateCard(index: number) {
    if (index < 0 || index >= totalCards) return;

    currentIndex = index;

    // Update card positions and flips
    cards.forEach((card, i) => {
      card.classList.remove('active', 'previous', 'hidden');

      if (i === currentIndex) {
        card.classList.add('active');
      } else if (i < currentIndex) {
        card.classList.add('previous');
      } else {
        card.classList.add('hidden');
      }
    });

    // Update stats
    updateStats(currentIndex);

    // Update progress
    if (currentIndex < yearLevels.length) {
      progressText!.textContent = `Level ${currentIndex + 1} / ${yearLevels.length}`;
    } else {
      progressText!.textContent = 'Journey Complete';
    }

    // Update navigation buttons
    if (navPrev) navPrev.style.opacity = currentIndex === 0 ? '0.3' : '1';
    if (navNext) navNext.style.opacity = currentIndex === totalCards - 1 ? '0.3' : '1';

    // Play random sprite animation
    playRandomAnimation();
  }

  // Navigation handlers
  navPrev?.addEventListener('click', () => {
    if (currentIndex > 0) {
      updateCard(currentIndex - 1);
    }
  });

  navNext?.addEventListener('click', () => {
    if (currentIndex < totalCards - 1) {
      updateCard(currentIndex + 1);
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') updateCard(currentIndex - 1);
    if (e.key === 'ArrowRight') updateCard(currentIndex + 1);
  });

  // Touch/swipe support
  let touchStartX = 0;
  cardStack?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  });

  cardStack?.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;

    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        updateCard(currentIndex + 1);
      } else {
        updateCard(currentIndex - 1);
      }
    }
  });

  // Mouse wheel navigation (desktop only)
  if (window.innerWidth > 768) {
    let isScrolling = false;
    cardStack?.addEventListener('wheel', (e) => {
      e.preventDefault();
      if (isScrolling) return;

      isScrolling = true;
      setTimeout(() => isScrolling = false, 600);

      if (e.deltaY > 0) {
        updateCard(currentIndex + 1);
      } else {
        updateCard(currentIndex - 1);
      }
    }, { passive: false });
  }

  // Initialize
  updateCard(0);
</script>

<style>
  .rpg-container {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(ellipse at top, rgba(123, 58, 237, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at bottom, rgba(16, 33, 62, 0.8) 0%, transparent 50%),
      linear-gradient(180deg, #0a0e27 0%, #1a1b26 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Larger Animated Sprite */
  .sprite-display {
    position: fixed;
    top: 50%;
    right: 50px;
    transform: translateY(-50%);
    z-index: 300;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .pixel-mage-large {
    width: 192px;
    height: 192px;
    padding: 16px;
    background: rgba(16, 21, 38, 0.9);
    border: 4px solid rgba(139, 92, 246, 0.6);
    border-radius: 16px;
    box-shadow:
      0 0 40px rgba(139, 92, 246, 0.5),
      inset 0 0 30px rgba(139, 92, 246, 0.1);
    backdrop-filter: blur(12px);
  }

  .mage-sprite {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 0 10px rgba(139, 92, 246, 0.7));
  }

  /* Sprite Animations */
  .glow {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  .mage-sprite.walk .left-foot {
    animation: walkLeft 0.4s ease-in-out;
  }

  .mage-sprite.walk .right-foot {
    animation: walkRight 0.4s ease-in-out;
  }

  @keyframes walkLeft {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  @keyframes walkRight {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(2px); }
  }

  .mage-sprite.scratch .left-eye,
  .mage-sprite.scratch .right-eye {
    animation: blink 0.3s ease-in-out;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .mage-sprite.shift {
    animation: shiftWeight 0.6s ease-in-out;
  }

  @keyframes shiftWeight {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-2px); }
    75% { transform: translateX(2px); }
  }

  .mage-sprite.twirl .staff {
    animation: staffTwirl 0.6s ease-in-out;
    transform-origin: center;
  }

  @keyframes staffTwirl {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(15deg); }
  }

  .sprite-label {
    font-size: 13px;
    font-weight: 700;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 6px 16px;
    background: rgba(139, 92, 246, 0.25);
    border-radius: 10px;
    border: 2px solid rgba(139, 92, 246, 0.4);
  }

  /* Stats Panel - Left Side, Near Card */
  .stats-panel {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-550px, -50%);
    z-index: 200;
    width: 260px;
    background: rgba(16, 21, 38, 0.95);
    border: 3px solid rgba(139, 92, 246, 0.5);
    border-radius: 16px;
    padding: 20px;
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .stats-header {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 800;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid rgba(139, 92, 246, 0.4);
  }

  .stats-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    background: rgba(139, 92, 246, 0.1);
    border-radius: 8px;
    font-size: 14px;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .stat-item.negative {
    background: rgba(248, 113, 113, 0.1);
    border-color: rgba(248, 113, 113, 0.3);
  }

  .stat-name {
    color: var(--sw-text-secondary);
    font-weight: 600;
  }

  .stat-value {
    color: #10b981;
    font-weight: 800;
    font-family: 'Monaco', monospace;
    font-size: 15px;
  }

  .stat-item.negative .stat-value {
    color: #f87171;
  }

  .stats-footer {
    padding-top: 12px;
    border-top: 2px solid rgba(139, 92, 246, 0.4);
    text-align: center;
  }

  .xp-display {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(251, 191, 36, 0.15);
    border: 2px solid rgba(251, 191, 36, 0.5);
    border-radius: 10px;
    color: #fbbf24;
    font-size: 16px;
    font-weight: 800;
    font-family: 'Monaco', monospace;
  }

  /* Card Stack Container */
  .card-stack-container {
    position: relative;
    width: 450px;
    height: 680px;
  }

  .card-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .card-wrapper {
    position: absolute;
    inset: 0;
    transition: transform 0.5s ease-out, opacity 0.5s ease-out;
  }

  /* Card States - Simple scroll-to-flip animation */
  .card-wrapper.hidden {
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    pointer-events: none;
  }

  .card-wrapper.active {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .card-wrapper.previous {
    transform: scale(0.9) translateY(-20px);
    opacity: 0;
    pointer-events: none;
  }

  /* Card Inner */
  .card-inner {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
  }

  /* Portrait Card Design */
  .card-portrait {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(16, 21, 38, 0.98) 100%);
    border: 4px solid;
    border-image: linear-gradient(135deg, #7c3aed, #6b21a8, #5b21b6) 1;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 25px 70px rgba(0, 0, 0, 0.6),
      0 0 50px rgba(139, 92, 246, 0.3),
      inset 0 0 40px rgba(139, 92, 246, 0.08);
    overflow: hidden;
  }

  .card-portrait::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg,
      transparent,
      rgba(167, 139, 250, 0.9),
      transparent
    );
  }

  /* Card Header Portrait */
  .card-header-portrait {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.4) 0%, rgba(107, 33, 168, 0.3) 100%);
    border-bottom: 3px solid rgba(139, 92, 246, 0.4);
  }

  .card-level-badge {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 2px;
    color: #fbbf24;
    text-transform: uppercase;
    padding: 6px 16px;
    background: rgba(251, 191, 36, 0.15);
    border: 2px solid rgba(251, 191, 36, 0.4);
    border-radius: 12px;
  }

  .card-year-badge {
    font-size: 26px;
    font-weight: 900;
    color: #a78bfa;
    font-family: 'Monaco', monospace;
  }

  /* Title Portrait */
  .card-title-portrait {
    padding: 24px 24px 20px;
    text-align: center;
    border-bottom: 2px solid rgba(139, 92, 246, 0.3);
  }

  .portrait-title {
    font-size: 32px;
    font-weight: 900;
    background: linear-gradient(135deg, #7FDBCA 0%, #C792EA 50%, #FF5874 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .portrait-subtitle {
    font-size: 15px;
    color: var(--sw-text-muted);
    font-style: italic;
  }

  /* Achievements Portrait */
  .achievements-portrait {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .achievements-portrait::-webkit-scrollbar {
    width: 6px;
  }

  .achievements-portrait::-webkit-scrollbar-track {
    background: rgba(139, 92, 246, 0.1);
    border-radius: 3px;
  }

  .achievements-portrait::-webkit-scrollbar-thumb {
    background: rgba(139, 92, 246, 0.5);
    border-radius: 3px;
  }

  .achievement-entry {
    display: flex;
    gap: 14px;
    padding: 16px;
    background: rgba(139, 92, 246, 0.06);
    border: 2px solid rgba(139, 92, 246, 0.2);
    border-radius: 12px;
    margin-bottom: 14px;
    transition: all 0.3s ease;
  }

  .achievement-entry:hover {
    border-color: rgba(139, 92, 246, 0.5);
    background: rgba(139, 92, 246, 0.12);
    transform: translateY(-2px);
  }

  .achievement-entry:last-child {
    margin-bottom: 0;
  }

  .achievement-icon-small {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #7c3aed, #6b21a8);
    border-radius: 10px;
    color: #fff;
    font-size: 20px;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.4);
  }

  .achievement-details {
    flex: 1;
    min-width: 0;
  }

  .achievement-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--sw-text-primary);
    margin-bottom: 6px;
  }

  .achievement-flavor {
    font-size: 13px;
    line-height: 1.5;
    color: var(--sw-text-secondary);
    margin-bottom: 10px;
  }

  .achievement-stats {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .xp-tag {
    padding: 4px 10px;
    background: rgba(251, 191, 36, 0.15);
    border: 1px solid rgba(251, 191, 36, 0.5);
    border-radius: 6px;
    color: #fbbf24;
    font-size: 12px;
    font-weight: 700;
  }

  .attrs-mini {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .attr-mini {
    padding: 3px 8px;
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.4);
    border-radius: 5px;
    font-size: 11px;
    font-weight: 600;
    color: #10b981;
  }

  .attr-mini.neg {
