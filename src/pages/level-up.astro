---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';

interface Achievement {
  year: number;
  title: string;
  description: string;
  icon: string;
  iconStyle: 'solid' | 'brands' | 'regular';
  xp: number;
}

interface Level {
  level: number;
  title: string;
  yearRange: string;
  achievements: Achievement[];
  totalXP: number;
}

const levels: Level[] = [
  {
    level: 1,
    title: 'The Awakening',
    yearRange: '2008-2012',
    totalXP: 650,
    achievements: [
      { year: 2008, title: 'Guitar Passion', description: 'Electric and acoustic guitar became lifelong passion', icon: 'guitar', iconStyle: 'solid', xp: 150 },
      { year: 2010, title: 'Stick Shift Trial', description: 'Bought Mazdaspeed3 without knowing manual', icon: 'car', iconStyle: 'solid', xp: 100 },
      { year: 2012, title: 'PowerShell Era', description: 'Began automating everything with PowerShell', icon: 'bolt', iconStyle: 'solid', xp: 200 },
      { year: 2012, title: 'SQL Deep Dive', description: 'Database optimization and query tuning mastery', icon: 'database', iconStyle: 'solid', xp: 200 },
    ]
  },
  {
    level: 2,
    title: 'Creative Expansion',
    yearRange: '2014-2017',
    totalXP: 550,
    achievements: [
      { year: 2015, title: 'Photography & Video', description: 'Started capturing light and visual stories', icon: 'camera', iconStyle: 'solid', xp: 200 },
      { year: 2016, title: 'Music Production', description: 'Dove into DAW and digital audio', icon: 'sliders', iconStyle: 'solid', xp: 75 },
      { year: 2017, title: 'Family Thanksgiving', description: 'Hosted family gathering, captured memories', icon: 'turkey', iconStyle: 'solid', xp: 75 },
    ]
  },
  {
    level: 3,
    title: 'Go Journey',
    yearRange: '2020-2021',
    totalXP: 300,
    achievements: [
      { year: 2020, title: 'Go Learning', description: 'Started 100 Days of Code with Go', icon: 'code-branch', iconStyle: 'solid', xp: 100 },
      { year: 2021, title: 'Go Career', description: 'Joined role using Go professionally', icon: 'code-merge', iconStyle: 'solid', xp: 200 },
    ]
  },
  {
    level: 4,
    title: 'Digital Nomad',
    yearRange: '2023',
    totalXP: 625,
    achievements: [
      { year: 2023, title: 'Digital Garden', description: 'Published personal knowledge base', icon: 'seedling', iconStyle: 'solid', xp: 100 },
      { year: 2023, title: 'Manual F150', description: 'Drove manual truck without stalling', icon: 'truck', iconStyle: 'solid', xp: 75 },
      { year: 2023, title: 'NYC Visit', description: 'Conquered concrete jungle', icon: 'building', iconStyle: 'solid', xp: 125 },
      { year: 2023, title: 'Paris Adventure', description: 'Led family through City of Lights', icon: 'tower-broadcast', iconStyle: 'solid', xp: 150 },
      { year: 2023, title: 'Versailles', description: 'Wandered grand palace grounds', icon: 'monument', iconStyle: 'solid', xp: 100 },
      { year: 2023, title: 'London & Chunnel', description: 'Crossed under English Channel', icon: 'train', iconStyle: 'solid', xp: 125 },
    ]
  },
  {
    level: 5,
    title: 'AI Era',
    yearRange: '2023-2024',
    totalXP: 125,
    achievements: [
      { year: 2023, title: 'Local AI', description: 'Set up Ollama with local LLMs', icon: 'microchip', iconStyle: 'solid', xp: 75 },
      { year: 2024, title: 'AI Diagnostics', description: 'Using GPT for troubleshooting', icon: 'brain', iconStyle: 'solid', xp: 50 },
    ]
  },
  {
    level: 6,
    title: 'Modern Stack',
    yearRange: '2025',
    totalXP: 150,
    achievements: [
      { year: 2025, title: 'Astro Migration', description: 'Migrated site to Astro for modern DX', icon: 'rocket', iconStyle: 'solid', xp: 150 },
    ]
  }
];

const totalXP = levels.reduce((sum, level) => sum + level.totalXP, 0);
---

<BaseLayout title="RPG Life Stats | Sheldon Hull" description="Life as an RPG adventure">
  <div class="rpg-container">
    <!-- Character that walks with scroll -->
    <div class="character-container">
      <div class="pixel-mage" id="mage">
        <!-- Pixel art mage using CSS -->
        <div class="mage-pixels"></div>
      </div>
    </div>

    <!-- Horizontal scrolling sections -->
    <div class="levels-wrapper" id="levelsWrapper">
      {levels.map((level, index) => (
        <section class="level-section" data-level={level.level}>
          <div class="level-content">
            <div class="level-header">
              <div class="level-badge">
                <span class="level-number">LVL {level.level}</span>
              </div>
              <h2 class="level-title">{level.title}</h2>
              <p class="level-years">{level.yearRange}</p>
              <div class="level-xp">
                <FAIcon style="solid" icon="star" />
                {level.totalXP} XP
              </div>
            </div>

            <div class="achievements-grid">
              {level.achievements.map((achievement) => (
                <div class="achievement-card">
                  <div class="achievement-icon">
                    <FAIcon style={achievement.iconStyle} icon={achievement.icon} />
                  </div>
                  <div class="achievement-info">
                    <h3 class="achievement-title">{achievement.title}</h3>
                    <p class="achievement-desc">{achievement.description}</p>
                    <span class="achievement-xp">+{achievement.xp} XP</span>
                  </div>
                  <div class="achievement-year">{achievement.year}</div>
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}

      <!-- Final section -->
      <section class="level-section final-section">
        <div class="level-content">
          <div class="final-stats">
            <h2 class="final-title">Journey Continues...</h2>
            <div class="total-stats">
              <div class="stat-box">
                <FAIcon style="solid" icon="trophy" />
                <span class="stat-value">{levels.length}</span>
                <span class="stat-label">Levels</span>
              </div>
              <div class="stat-box">
                <FAIcon style="solid" icon="star" />
                <span class="stat-value">{totalXP}</span>
                <span class="stat-label">Total XP</span>
              </div>
              <div class="stat-box">
                <FAIcon style="solid" icon="award" />
                <span class="stat-value">{levels.reduce((sum, l) => sum + l.achievements.length, 0)}</span>
                <span class="stat-label">Achievements</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Navigation controls (mobile) -->
    <button class="nav-btn nav-prev" id="navPrev" aria-label="Previous level">
      <FAIcon style="solid" icon="chevron-left" />
    </button>
    <button class="nav-btn nav-next" id="navNext" aria-label="Next level">
      <FAIcon style="solid" icon="chevron-right" />
    </button>

    <!-- Level indicator dots -->
    <div class="level-dots">
      {levels.map((level, index) => (
        <button class="dot" data-index={index} class:list={[{ active: index === 0 }]}>
          <span class="sr-only">Level {level.level}</span>
        </button>
      ))}
      <button class="dot" data-index={levels.length}>
        <span class="sr-only">Stats</span>
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  let currentSection = 0;
  const wrapper = document.getElementById('levelsWrapper');
  const mage = document.getElementById('mage');
  const sections = document.querySelectorAll('.level-section');
  const dots = document.querySelectorAll('.dot');
  const navPrev = document.getElementById('navPrev');
  const navNext = document.getElementById('navNext');

  let isScrolling = false;
  let touchStartX = 0;
  let touchEndX = 0;

  function updateSection(index: number) {
    if (index < 0 || index >= sections.length) return;

    currentSection = index;
    const scrollAmount = currentSection * window.innerWidth;

    wrapper?.scrollTo({
      left: scrollAmount,
      behavior: 'smooth'
    });

    // Update dots
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSection);
    });

    // Animate mage walking
    if (mage) {
      const progress = (currentSection / (sections.length - 1)) * 100;
      mage.style.left = `${Math.min(progress, 85)}%`;
      mage.classList.add('walking');
      setTimeout(() => mage.classList.remove('walking'), 600);
    }

    // Update nav buttons
    if (navPrev) navPrev.style.opacity = currentSection === 0 ? '0.3' : '1';
    if (navNext) navNext.style.opacity = currentSection === sections.length - 1 ? '0.3' : '1';
  }

  // Wheel scroll
  wrapper?.addEventListener('wheel', (e) => {
    e.preventDefault();
    if (isScrolling) return;

    isScrolling = true;
    setTimeout(() => isScrolling = false, 800);

    if (e.deltaY > 0 || e.deltaX > 0) {
      updateSection(currentSection + 1);
    } else if (e.deltaY < 0 || e.deltaX < 0) {
      updateSection(currentSection - 1);
    }
  }, { passive: false });

  // Touch/swipe support
  wrapper?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  });

  wrapper?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].clientX;
    handleSwipe();
  });

  function handleSwipe() {
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        updateSection(currentSection + 1);
      } else {
        updateSection(currentSection - 1);
      }
    }
  }

  // Navigation buttons
  navPrev?.addEventListener('click', () => updateSection(currentSection - 1));
  navNext?.addEventListener('click', () => updateSection(currentSection + 1));

  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => updateSection(index));
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') updateSection(currentSection + 1);
    if (e.key === 'ArrowLeft') updateSection(currentSection - 1);
  });

  // Initialize
  updateSection(0);
</script>

<style>
  .rpg-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: linear-gradient(180deg, #0a0e27 0%, #1a1b26 50%, #16213e 100%);
  }

  .character-container {
    position: fixed;
    bottom: 60px;
    left: 10%;
    z-index: 100;
    pointer-events: none;
  }

  .pixel-mage {
    width: 64px;
    height: 64px;
    position: relative;
    transition: left 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
  }

  .pixel-mage.walking {
    animation: walk 0.6s steps(4);
  }

  @keyframes walk {
    0%, 100% { transform: translateY(0); }
    25% { transform: translateY(-2px); }
    75% { transform: translateY(-2px); }
  }

  /* Pixel art mage using CSS */
  .mage-pixels {
    width: 100%;
    height: 100%;
    background:
      /* Hood */
      radial-gradient(circle at 50% 20%, #6b46c1 0%, #6b46c1 30%, transparent 30%),
      /* Body */
      linear-gradient(180deg, #7c3aed 40%, #5b21b6 70%, #4c1d95 100%),
      /* Staff glow */
      radial-gradient(circle at 85% 50%, #fbbf24 0%, #f59e0b 15%, transparent 25%);
    box-shadow:
      0 0 20px rgba(139, 92, 246, 0.6),
      inset 0 0 10px rgba(167, 139, 250, 0.3);
    border-radius: 4px;
    position: relative;
  }

  .mage-pixels::before {
    content: '';
    position: absolute;
    width: 4px;
    height: 40px;
    background: #92400e;
    right: 8px;
    top: 20px;
    border-radius: 1px;
  }

  .mage-pixels::after {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background: #fbbf24;
    right: 5px;
    top: 15px;
    border-radius: 50%;
    box-shadow: 0 0 12px #fbbf24;
    animation: pulse 2s infinite;
  }

  .levels-wrapper {
    display: flex;
    height: 100vh;
    overflow-x: hidden;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }

  .level-section {
    min-width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 40px 120px;
    scroll-snap-align: start;
    position: relative;
  }

  .level-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(139, 92, 246, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .level-content {
    max-width: 1200px;
    width: 100%;
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .level-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .level-badge {
    display: inline-block;
    margin-bottom: 16px;
  }

  .level-number {
    display: inline-block;
    padding: 8px 24px;
    background: linear-gradient(135deg, #7c3aed 0%, #6b21a8 100%);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2px;
    border-radius: 20px;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.4);
    text-transform: uppercase;
  }

  .level-title {
    font-size: 48px;
    font-weight: 800;
    background: linear-gradient(135deg, #7FDBCA 0%, #C792EA 50%, #FF5874 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  .level-years {
    font-size: 18px;
    color: var(--sw-text-muted);
    margin-bottom: 12px;
  }

  .level-xp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 12px;
    color: #fbbf24;
    font-weight: 600;
    font-size: 14px;
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .achievement-card {
    background: rgba(139, 92, 246, 0.05);
    border: 2px solid rgba(139, 92, 246, 0.2);
    border-radius: 12px;
    padding: 20px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .achievement-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #7c3aed, #c792ea);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .achievement-card:hover {
    border-color: rgba(139, 92, 246, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(139, 92, 246, 0.2);
  }

  .achievement-card:hover::before {
    transform: scaleX(1);
  }

  .achievement-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #7c3aed 0%, #6b21a8 100%);
    border-radius: 12px;
    color: #fff;
    font-size: 24px;
    margin-bottom: 16px;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
  }

  .achievement-info {
    flex: 1;
  }

  .achievement-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--sw-text-primary);
    margin-bottom: 8px;
  }

  .achievement-desc {
    font-size: 14px;
    color: var(--sw-text-secondary);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .achievement-xp {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 8px;
    color: #fbbf24;
    font-size: 12px;
    font-weight: 600;
  }

  .achievement-year {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 12px;
    color: var(--sw-text-muted);
    font-weight: 600;
  }

  .final-section {
    background: radial-gradient(
      ellipse at center,
      rgba(124, 58, 237, 0.15) 0%,
      transparent 70%
    );
  }

  .final-stats {
    text-align: center;
  }

  .final-title {
    font-size: 56px;
    font-weight: 900;
    background: linear-gradient(135deg, #7FDBCA 0%, #C792EA 50%, #FF5874 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 48px;
  }

  .total-stats {
    display: flex;
    gap: 32px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .stat-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 32px;
    background: rgba(139, 92, 246, 0.1);
    border: 2px solid rgba(139, 92, 246, 0.3);
    border-radius: 16px;
    min-width: 180px;
    transition: all 0.3s ease;
  }

  .stat-box:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(139, 92, 246, 0.3);
    border-color: rgba(139, 92, 246, 0.6);
  }

  .stat-box :global(svg) {
    font-size: 40px;
    color: #7c3aed;
  }

  .stat-value {
    font-size: 48px;
    font-weight: 900;
    color: var(--sw-text-primary);
  }

  .stat-label {
    font-size: 14px;
    color: var(--sw-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Navigation */
  .nav-btn {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: rgba(139, 92, 246, 0.2);
    border: 2px solid rgba(139, 92, 246, 0.4);
    border-radius: 50%;
    color: #a78bfa;
    font-size: 20px;
    cursor: pointer;
    z-index: 50;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .nav-btn:hover {
    background: rgba(139, 92, 246, 0.4);
    border-color: rgba(139, 92, 246, 0.8);
    transform: translateY(-50%) scale(1.1);
  }

  .nav-prev { left: 20px; }
  .nav-next { right: 20px; }

  .level-dots {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 50;
  }

  .dot {
    width: 12px;
    height: 12px;
    background: rgba(139, 92, 246, 0.3);
    border: 2px solid rgba(139, 92, 246, 0.5);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: #7c3aed;
    border-color: #7c3aed;
    box-shadow: 0 0 12px rgba(124, 58, 237, 0.6);
    transform: scale(1.3);
  }

  .dot:hover {
    background: rgba(139, 92, 246, 0.6);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .level-title {
      font-size: 32px;
    }

    .final-title {
      font-size: 36px;
    }

    .achievements-grid {
      grid-template-columns: 1fr;
    }

    .level-section {
      padding: 60px 20px 100px;
    }

    .character-container {
      bottom: 80px;
      left: 5%;
    }

    .pixel-mage {
      width: 48px;
      height: 48px;
    }

    .nav-btn {
      width: 40px;
      height: 40px;
      font-size: 16px;
    }

    .total-stats {
      gap: 16px;
    }

    .stat-box {
      min-width: 140px;
      padding: 24px;
    }

    .stat-value {
      font-size: 36px;
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(1.2);
    }
  }
</style>
