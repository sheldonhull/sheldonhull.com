---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';
import {
  yearLevels,
  getTotalXP,
  getTotalAchievements,
  getFinalStats,
  type Stats
} from '../data/levelUpData';

const totalXP = getTotalXP();
const totalAchievements = getTotalAchievements();
const finalStats = getFinalStats();

// Sort stats by absolute value (highest to lowest), positives before negatives at same magnitude
const sortedFinalStats = Object.entries(finalStats)
  .sort((a, b) => {
    const absCompare = Math.abs(b[1]) - Math.abs(a[1]);
    if (absCompare !== 0) return absCompare;
    // Same absolute value: positive before negative
    return b[1] - a[1];
  });
---

<BaseLayout title="Life RPG | Sheldon Hull" description="Life as an RPG adventure - achievements, stats, and the journey so far">
  <div class="rpg-page">
    <!-- Sticky Hero Header -->
    <header class="hero-header">
      <div class="hero-content">
        <!-- Compact Mage Avatar -->
        <div class="hero-avatar">
          <div class="mage-frame">
            <svg viewBox="0 0 32 32" class="mage-svg">
              <rect x="10" y="3" width="12" height="2" fill="#6b46c1"/>
              <rect x="8" y="5" width="16" height="2" fill="#6b46c1"/>
              <rect x="7" y="7" width="18" height="3" fill="#7c3aed"/>
              <rect x="12" y="10" width="8" height="6" fill="#d4a574"/>
              <rect x="13" y="12" width="2" height="1" fill="#4a2511"/>
              <rect x="17" y="12" width="2" height="1" fill="#4a2511"/>
              <rect x="14" y="14" width="4" height="1" fill="#c48b5c" opacity="0.6"/>
              <rect x="9" y="16" width="14" height="2" fill="#8b5cf6"/>
              <rect x="8" y="18" width="16" height="5" fill="#7c3aed"/>
              <rect x="7" y="23" width="18" height="4" fill="#6b21a8"/>
              <rect x="9" y="27" width="5" height="4" fill="#5b21b6"/>
              <rect x="18" y="27" width="5" height="4" fill="#5b21b6"/>
              <rect x="26" y="14" width="2" height="15" fill="#92400e"/>
              <rect x="25" y="12" width="4" height="4" fill="#fbbf24" opacity="0.8"/>
              <circle cx="27" cy="14" r="2.5" fill="#fde047" opacity="0.9" class="orb"/>
              <circle cx="27" cy="14" r="3.5" fill="#fbbf24" opacity="0.3" class="glow"/>
            </svg>
          </div>
          <span class="level-tag">LVL {yearLevels.length}</span>
        </div>

        <!-- Summary Stats Row -->
        <div class="hero-stats">
          <div class="stat-pill">
            <FAIcon style="solid" icon="star" />
            <span class="stat-number">{totalXP.toLocaleString()}</span>
            <span class="stat-label">XP</span>
          </div>
          <div class="stat-pill">
            <FAIcon style="solid" icon="trophy" />
            <span class="stat-number">{totalAchievements}</span>
            <span class="stat-label">Achievements</span>
          </div>
          <div class="stat-pill">
            <FAIcon style="solid" icon="calendar" />
            <span class="stat-number">{yearLevels[yearLevels.length - 1].year - yearLevels[0].year + 1}</span>
            <span class="stat-label">Years</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Timeline Content -->
    <main class="timeline-container">
      <!-- Top Stats Summary -->
      <section class="top-stats-section">
        <h2 class="section-title">
          <FAIcon style="solid" icon="chart-line" />
          <span>Character Attributes</span>
        </h2>
        <div class="stats-badge-row">
          {sortedFinalStats.slice(0, 8).map(([name, value]) => (
            <span class={`stat-badge ${value < 0 ? 'negative' : 'positive'}`}>
              <span class="badge-name">{name}</span>
              <span class="badge-value">{value > 0 ? '+' : ''}{value}</span>
            </span>
          ))}
        </div>
        <button class="show-all-stats-btn" id="showAllStatsBtn">
          Show all {sortedFinalStats.length} stats
          <FAIcon style="solid" icon="chevron-down" />
        </button>
        <div class="all-stats-panel hidden" id="allStatsPanel">
          <div class="stats-badge-row expanded">
            {sortedFinalStats.map(([name, value]) => (
              <span class={`stat-badge ${value < 0 ? 'negative' : 'positive'}`}>
                <span class="badge-name">{name}</span>
                <span class="badge-value">{value > 0 ? '+' : ''}{value}</span>
              </span>
            ))}
          </div>
        </div>
      </section>

      <!-- Timeline of Levels -->
      <section class="timeline">
        {yearLevels.slice().reverse().map((level) => (
          <article class="year-card">
            <div class="year-header">
              <div class="year-badge">{level.year}</div>
              <div class="year-info">
                <h2 class="year-title">{level.title}</h2>
                <p class="year-subtitle">{level.subtitle}</p>
              </div>
              <div class="level-badge">LVL {level.level}</div>
            </div>

            <div class="achievements-grid">
              {level.achievements.map((achievement) => (
                <div class="achievement-card">
                  <div class="achievement-icon-glow">
                    <FAIcon style={achievement.iconStyle} icon={achievement.icon} />
                  </div>
                  <div class="achievement-content">
                    <div class="achievement-header">
                      <h3 class="achievement-title">{achievement.title}</h3>
                      <span class="xp-badge">+{achievement.xp} XP</span>
                    </div>
                    <p class="achievement-desc">{achievement.description}</p>
                    <div class="achievement-attrs">
                      {achievement.attributes
                        .slice()
                        .sort((a, b) => {
                          const absCompare = Math.abs(b.value) - Math.abs(a.value);
                          if (absCompare !== 0) return absCompare;
                          return b.value - a.value;
                        })
                        .map((attr) => (
                        <span class={`attr-tag ${attr.value < 0 ? 'negative' : 'positive'}`}>
                          {attr.name} {attr.value > 0 ? '+' : ''}{attr.value}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="year-footer">
              <span class="year-xp">
                <FAIcon style="solid" icon="star" />
                {level.achievements.reduce((sum, a) => sum + a.xp, 0)} XP this year
              </span>
              <span class="achievement-count">
                <FAIcon style="solid" icon="award" />
                {level.achievements.length} {level.achievements.length === 1 ? 'achievement' : 'achievements'}
              </span>
            </div>
          </article>
        ))}
      </section>

      <!-- Journey Complete Footer -->
      <footer class="journey-complete">
        <div class="complete-header">
          <div class="complete-mage">
            <svg viewBox="0 0 32 32" class="complete-mage-svg">
              <rect x="10" y="3" width="12" height="2" fill="#6b46c1"/>
              <rect x="8" y="5" width="16" height="2" fill="#6b46c1"/>
              <rect x="7" y="7" width="18" height="3" fill="#7c3aed"/>
              <rect x="12" y="10" width="8" height="6" fill="#d4a574"/>
              <rect x="13" y="12" width="2" height="1" fill="#4a2511"/>
              <rect x="17" y="12" width="2" height="1" fill="#4a2511"/>
              <rect x="14" y="14" width="4" height="1" fill="#c48b5c" opacity="0.6"/>
              <rect x="9" y="16" width="14" height="2" fill="#8b5cf6"/>
              <rect x="8" y="18" width="16" height="5" fill="#7c3aed"/>
              <rect x="7" y="23" width="18" height="4" fill="#6b21a8"/>
              <rect x="9" y="27" width="5" height="4" fill="#5b21b6"/>
              <rect x="18" y="27" width="5" height="4" fill="#5b21b6"/>
              <rect x="26" y="14" width="2" height="15" fill="#92400e"/>
              <rect x="25" y="12" width="4" height="4" fill="#fbbf24" opacity="0.8"/>
              <circle cx="27" cy="14" r="2.5" fill="#fde047" opacity="0.9"/>
              <circle cx="27" cy="14" r="3.5" fill="#fbbf24" opacity="0.3"/>
            </svg>
          </div>
          <div class="complete-text">
            <h2 class="complete-title">Journey in Progress</h2>
            <p class="complete-subtitle">The adventure continues...</p>
          </div>
        </div>

        <div class="final-summary">
          <div class="summary-card">
            <FAIcon style="solid" icon="trophy" />
            <span class="summary-value">{yearLevels.length}</span>
            <span class="summary-label">Levels</span>
          </div>
          <div class="summary-card highlight">
            <FAIcon style="solid" icon="star" />
            <span class="summary-value">{totalXP.toLocaleString()}</span>
            <span class="summary-label">Total XP</span>
          </div>
          <div class="summary-card">
            <FAIcon style="solid" icon="award" />
            <span class="summary-value">{totalAchievements}</span>
            <span class="summary-label">Achievements</span>
          </div>
        </div>

        <div class="final-all-stats">
          <h3 class="final-stats-title">All Character Attributes</h3>
          <div class="final-stats-grid">
            {sortedFinalStats.map(([name, value]) => (
              <div class={`final-stat-item ${value < 0 ? 'negative' : ''}`}>
                <span class="final-stat-name">{name}</span>
                <span class="final-stat-value">{value > 0 ? '+' : ''}{value}</span>
              </div>
            ))}
          </div>
        </div>
      </footer>
    </main>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
      <FAIcon style="solid" icon="chevron-up" />
    </button>
  </div>
</BaseLayout>

<script>
  // Show/hide all stats toggle
  const showAllStatsBtn = document.getElementById('showAllStatsBtn');
  const allStatsPanel = document.getElementById('allStatsPanel');

  showAllStatsBtn?.addEventListener('click', () => {
    allStatsPanel?.classList.toggle('hidden');
    const isHidden = allStatsPanel?.classList.contains('hidden');
    if (showAllStatsBtn) {
      const icon = showAllStatsBtn.querySelector('svg');
      if (icon) {
        icon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
      }
    }
  });

  // Back to top button
  const backToTop = document.getElementById('backToTop');

  const handleScroll = () => {
    if (backToTop) {
      if (window.scrollY > 400) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Animate elements on scroll
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.year-card, .achievement-card').forEach(el => {
    observer.observe(el);
  });
</script>

<style>
  /* ===== Base Layout ===== */
  .rpg-page {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at top, rgba(123, 58, 237, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at bottom, rgba(16, 33, 62, 0.6) 0%, transparent 50%),
      linear-gradient(180deg, #0a0e27 0%, #1a1b26 100%);
  }

  /* ===== Hero Header ===== */
  .hero-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 39, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid rgba(139, 92, 246, 0.3);
    padding: 12px 16px;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .hero-avatar {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mage-frame {
    width: 52px;
    height: 52px;
    padding: 6px;
    background: rgba(139, 92, 246, 0.2);
    border: 2px solid rgba(139, 92, 246, 0.5);
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
  }

  .mage-svg {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }

  .orb {
    animation: pulse 2s ease-in-out infinite;
  }

  .glow {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.9; }
  }

  .level-tag {
    padding: 6px 12px;
    background: linear-gradient(135deg, #7c3aed, #6b21a8);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 1px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  .hero-stats {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    flex: 1;
    justify-content: flex-end;
  }

  .stat-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 20px;
    color: var(--sw-text-secondary);
    font-size: 13px;
  }

  .stat-pill :global(svg) {
    color: #fbbf24;
    font-size: 14px;
  }

  .stat-number {
    font-weight: 800;
    color: var(--sw-text-primary);
    font-family: 'Monaco', monospace;
  }

  .stat-label {
    color: var(--sw-text-muted);
    font-size: 11px;
  }

  /* ===== Main Content ===== */
  .timeline-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 16px 60px;
  }

  /* ===== Top Stats Section ===== */
  .top-stats-section {
    margin-bottom: 32px;
    padding: 20px;
    background: rgba(139, 92, 246, 0.08);
    border: 2px solid rgba(139, 92, 246, 0.25);
    border-radius: 16px;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
  }

  .section-title :global(svg) {
    font-size: 16px;
  }

  .stats-badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .stats-badge-row.expanded {
    margin-bottom: 0;
  }

  .stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    transition: transform 0.2s ease;
  }

  .stat-badge:hover {
    transform: scale(1.05);
  }

  .stat-badge.positive {
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.4);
    color: #10b981;
  }

  .stat-badge.negative {
    background: rgba(248, 113, 113, 0.15);
    border: 1px solid rgba(248, 113, 113, 0.4);
    color: #f87171;
  }

  .badge-name {
    color: var(--sw-text-secondary);
  }

  .badge-value {
    font-weight: 800;
    font-family: 'Monaco', monospace;
  }

  .show-all-stats-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 8px 16px;
    background: transparent;
    border: 1px solid rgba(139, 92, 246, 0.4);
    border-radius: 8px;
    color: #a78bfa;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .show-all-stats-btn:hover {
    background: rgba(139, 92, 246, 0.15);
    border-color: rgba(139, 92, 246, 0.6);
  }

  .show-all-stats-btn :global(svg) {
    transition: transform 0.3s ease;
    font-size: 10px;
  }

  .all-stats-panel {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(139, 92, 246, 0.2);
  }

  .all-stats-panel.hidden {
    display: none;
  }

  /* ===== Timeline ===== */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .year-card {
    background: rgba(16, 21, 38, 0.8);
    border: 2px solid rgba(139, 92, 246, 0.25);
    border-radius: 16px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  /* Alternate year card backgrounds for visual distinction */
  .year-card:nth-child(odd) {
    background: rgba(16, 21, 38, 0.85);
    border-color: rgba(139, 92, 246, 0.3);
  }

  .year-card:nth-child(odd) .year-header {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.25) 0%, rgba(107, 33, 168, 0.2) 100%);
  }

  .year-card:nth-child(even) {
    background: rgba(20, 27, 48, 0.85);
    border-color: rgba(127, 219, 202, 0.25);
  }

  .year-card:nth-child(even) .year-header {
    background: linear-gradient(135deg, rgba(127, 219, 202, 0.15) 0%, rgba(16, 33, 62, 0.2) 100%);
    border-bottom-color: rgba(127, 219, 202, 0.2);
  }

  .year-card:nth-child(even) .year-badge {
    color: #7FDBCA;
  }

  .year-card:nth-child(even) .year-footer {
    border-top-color: rgba(127, 219, 202, 0.15);
  }

  .year-card.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .year-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(107, 33, 168, 0.15) 100%);
    border-bottom: 2px solid rgba(139, 92, 246, 0.2);
    flex-wrap: wrap;
  }

  .year-badge {
    font-size: 24px;
    font-weight: 900;
    color: #a78bfa;
    font-family: 'Monaco', monospace;
    min-width: 60px;
  }

  .year-info {
    flex: 1;
    min-width: 200px;
  }

  .year-title {
    font-size: 18px;
    font-weight: 800;
    background: linear-gradient(135deg, #7FDBCA 0%, #C792EA 50%, #FF5874 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
  }

  .year-subtitle {
    font-size: 13px;
    color: var(--sw-text-muted);
    font-style: italic;
  }

  .level-badge {
    padding: 6px 14px;
    background: rgba(251, 191, 36, 0.15);
    border: 2px solid rgba(251, 191, 36, 0.4);
    border-radius: 10px;
    color: #fbbf24;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1px;
  }

  /* ===== Achievement Cards ===== */
  .achievements-grid {
    display: grid;
    gap: 12px;
    padding: 16px;
  }

  .achievement-card {
    display: flex;
    gap: 16px;
    padding: 14px 14px 14px 0;
    background: rgba(139, 92, 246, 0.04);
    border: none;
    border-radius: 12px;
    transition: all 0.2s ease;
    opacity: 0;
    transform: translateX(-10px);
    position: relative;
  }

  .achievement-card.animate-in {
    opacity: 1;
    transform: translateX(0);
  }

  .achievement-card:hover {
    background: rgba(139, 92, 246, 0.08);
  }

  .achievement-card:hover .achievement-icon-glow {
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.9), 0 0 40px rgba(139, 92, 246, 0.6);
  }

  .achievement-card:hover .achievement-icon-glow::before {
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.8), 0 0 40px rgba(139, 92, 246, 0.5);
  }

  /* Left border icon style with neon glow */
  .achievement-icon-glow {
    flex-shrink: 0;
    width: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a78bfa;
    font-size: 22px;
    position: relative;
    text-shadow: 0 0 12px rgba(139, 92, 246, 0.7), 0 0 24px rgba(139, 92, 246, 0.4);
    transition: all 0.3s ease;
  }

  .achievement-icon-glow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 70%;
    background: linear-gradient(180deg, #7c3aed, #a78bfa);
    border-radius: 2px;
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.6), 0 0 24px rgba(139, 92, 246, 0.3);
    transition: all 0.3s ease;
  }

  .achievement-icon-glow :global(svg) {
    filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.5));
  }

  .achievement-content {
    flex: 1;
    min-width: 0;
  }

  .achievement-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .achievement-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--sw-text-primary);
  }

  .xp-badge {
    flex-shrink: 0;
    padding: 3px 10px;
    background: rgba(251, 191, 36, 0.15);
    border: 1px solid rgba(251, 191, 36, 0.4);
    border-radius: 12px;
    color: #fbbf24;
    font-size: 11px;
    font-weight: 700;
  }

  .achievement-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--sw-text-secondary);
    margin-bottom: 10px;
  }

  .achievement-attrs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .attr-tag {
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
  }

  .attr-tag.positive {
    background: rgba(16, 185, 129, 0.12);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #10b981;
  }

  .attr-tag.negative {
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.3);
    color: #f87171;
  }

  /* ===== Year Footer ===== */
  .year-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
