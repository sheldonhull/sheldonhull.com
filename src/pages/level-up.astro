---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';

interface Event {
  date: string; // YYYY-MM or YYYY
  category: string;
  blurb: string;
  icon: string;
  iconStyle: 'solid' | 'brands' | 'regular';
  color: 'cyan' | 'purple' | 'pink' | 'yellow';
  type: 'commit' | 'branch' | 'merge'; // Git graph types
  xp: number;
}

// Chronological order: newest first
const events: Event[] = [
  {
    date: '2023-12',
    category: 'London & Chunnel',
    blurb: 'Crossed under the English Channel by train, explored London pubs',
    icon: 'train',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'commit',
    xp: 125,
  },
  {
    date: '2023-11',
    category: 'Palace of Versailles',
    blurb: 'Wandered the grand palace grounds and gardens outside Paris',
    icon: 'monument',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'commit',
    xp: 100,
  },
  {
    date: '2023-11',
    category: 'Paris Adventure',
    blurb: 'Led family through City of Lights, navigated metro system, experienced French culture',
    icon: 'tower-broadcast',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'merge',
    xp: 150,
  },
  {
    date: '2023-11',
    category: 'First NYC Visit',
    blurb: 'Conquered the concrete jungle with family, won the rat-spotting challenge',
    icon: 'building',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'branch',
    xp: 125,
  },
  {
    date: '2023-10',
    category: 'Beast Tamer',
    blurb: 'Drove manual transmission F150 for first time without stalling once',
    icon: 'truck',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2023-03',
    category: 'Digital Garden',
    blurb: 'Published personal knowledge base and digital garden to the web',
    icon: 'seedling',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 100,
  },
  {
    date: '2021-08',
    category: 'Go Development: Merge to Main',
    blurb: 'Joined Dataleon using Go professionally, journey from learning to career',
    icon: 'golang',
    iconStyle: 'brands',
    color: 'cyan',
    type: 'merge',
    xp: 200,
  },
  {
    date: '2020-06',
    category: 'Go Journey: Branch Created',
    blurb: 'Started 100 Days of Code with Go, building automation and DevOps tools',
    icon: 'code-branch',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'branch',
    xp: 100,
  },
  {
    date: '2017-11',
    category: 'Family Thanksgiving',
    blurb: 'Hosted family gathering, captured memories on video',
    icon: 'turkey',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2016',
    category: 'Music Production',
    blurb: 'Dove into DAW (Studio One), exploring digital audio architecture',
    icon: 'sliders',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2015',
    category: 'Photography & Videography',
    blurb: 'Started capturing light and crafting visual stories frame by frame',
    icon: 'camera',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 200,
  },
  {
    date: '2014',
    category: 'SQL Sorcery',
    blurb: 'Deep dive into database optimization, query tuning, and schema design',
    icon: 'database',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'commit',
    xp: 200,
  },
  {
    date: '2012',
    category: 'PowerShell Automation',
    blurb: 'Began automating everything with PowerShell scripting and pipelines',
    icon: 'bolt',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'commit',
    xp: 200,
  },
  {
    date: '2010',
    category: 'Stick Shift Mastery',
    blurb: 'Bought Mazdaspeed3 without knowing manual, learned through trial by fire',
    icon: 'car',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 100,
  },
  {
    date: '~2008',
    category: 'Six-String Bard',
    blurb: 'Electric and acoustic guitar became lifelong passion, post-rock soundtrack',
    icon: 'guitar',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 150,
  },
  {
    date: '~2000s',
    category: 'Parent Class: Unlocked',
    blurb: 'Three kids, endless adventures, party leader of family expeditions',
    icon: 'baby',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 500,
  },
];

const totalXP = events.reduce((sum, e) => sum + e.xp, 0);
const level = Math.floor(totalXP / 100) + 1;

const colorMap = {
  cyan: 'var(--sw-cyan)',
  purple: 'var(--sw-purple)',
  pink: 'var(--sw-pink)',
  yellow: 'var(--sw-yellow)',
};

const getGraphChar = (type: string) => {
  switch (type) {
    case 'branch':
      return '┬';
    case 'merge':
      return '┴';
    default:
      return '●';
  }
};
---

<BaseLayout title="Level Up - Life RPG | Sheldon Hull" description="Life journey as a git graph">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold mb-3 synthwave-gradient">
        <FAIcon style="solid" icon="code-branch" class="mr-2" />
        Life Git Graph
      </h1>
      <p class="text-sm" style="color: var(--sw-text-secondary);">
        Level {level} · {totalXP.toLocaleString()} XP · Commits, Branches & Merges
      </p>
    </div>

    <!-- Git Graph -->
    <div class="font-mono text-sm relative">
      {
        events.map((event, index) => {
          const color = colorMap[event.color];
          const nextEvent = events[index + 1];
          const isBranch = event.type === 'branch';
          const isMerge = event.type === 'merge';
          const graphChar = getGraphChar(event.type);

          return (
            <div class="group mb-6">
              {/* Git line */}
              <div class="flex items-start gap-3">
                {/* Date */}
                <div class="text-xs pt-1 w-16 flex-shrink-0" style="color: var(--sw-text-muted);">
                  {event.date}
                </div>

                {/* Graph character */}
                <div class="flex-shrink-0 w-8 flex items-center justify-center">
                  <div
                    class="w-6 h-6 rounded-full flex items-center justify-center text-base font-bold transition-all group-hover:scale-110"
                    style={`background: ${color}; color: var(--sw-bg-primary);`}
                  >
                    <FAIcon style={event.iconStyle} icon={event.icon} class="text-sm" />
                  </div>
                </div>

                {/* Content */}
                <div class="flex-1 min-w-0 pb-3">
                  <div class="flex items-baseline gap-2 mb-1 flex-wrap">
                    <span class="font-semibold" style={`color: ${color};`}>
                      {event.category}
                    </span>
                    <span class="text-xs px-1.5 py-0.5 rounded" style={`background: ${color}33; color: ${color};`}>
                      +{event.xp}
                    </span>
                  </div>
                  <p class="text-xs leading-relaxed" style="color: var(--sw-text-secondary);">
                    {event.blurb}
                  </p>
                </div>
              </div>

              {/* Connecting line */}
              {nextEvent && (
                <div class="flex">
                  <div class="w-16 flex-shrink-0"></div>
                  <div class="w-8 flex justify-center">
                    <div
                      class="w-0.5 h-4"
                      style={`background: ${isBranch || isMerge ? color : 'var(--sw-cyan)'};`}
                    ></div>
                  </div>
                </div>
              )}
            </div>
          );
        })
      }

      {/* End */}
      <div class="flex items-center gap-3 mt-6 text-xs" style="color: var(--sw-text-muted);">
        <div class="w-16"></div>
        <div class="w-8 flex justify-center">
          <div
            class="w-3 h-3 rounded-full"
            style="background: var(--sw-cyan); box-shadow: 0 0 8px var(--sw-cyan);"
          ></div>
        </div>
        <span>
          <FAIcon style="solid" icon="infinity" class="mr-1" />
          The journey continues...
        </span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .synthwave-gradient {
    background: linear-gradient(45deg, var(--sw-cyan), var(--sw-purple), var(--sw-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
