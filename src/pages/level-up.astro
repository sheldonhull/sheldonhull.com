---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';

interface Event {
  date: string;
  title: string;
  blurb: string;
  icon: string;
  iconStyle: 'solid' | 'brands' | 'regular';
  color: 'cyan' | 'purple' | 'pink' | 'yellow';
  type: 'commit' | 'branch-start' | 'branch-commit' | 'branch-end' | 'tag';
  branchLevel?: number; // 0 = main, 1 = first branch, 2 = nested
  xp: number;
  tag?: string;
}

const events: Event[] = [
  {
    date: '2025-11',
    title: 'Hugo → Astro Migration',
    blurb: 'Migrated entire site from Hugo static generator to Astro for better DX and modern tooling',
    icon: 'rocket',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'tag',
    tag: 'v3.0.0',
    xp: 150,
  },
  {
    date: '2024-10',
    title: 'AI for Diagnostics',
    blurb: 'Started using GPT/ChatGPT for troubleshooting audio equipment and general problem-solving',
    icon: 'brain',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 50,
  },
  {
    date: '2023-12',
    title: 'Local AI Exploration',
    blurb: 'Set up Ollama to run local LLMs (llama2:13b) on M2 Max, exploring AI tooling',
    icon: 'microchip',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2023-12',
    title: 'London & Chunnel',
    blurb: 'Crossed under English Channel by train, explored London pubs with family',
    icon: 'train',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'branch-end',
    branchLevel: 1,
    xp: 125,
  },
  {
    date: '2023-11',
    title: 'Palace of Versailles',
    blurb: 'Wandered grand palace grounds and gardens outside Paris',
    icon: 'monument',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'branch-commit',
    branchLevel: 1,
    xp: 100,
  },
  {
    date: '2023-11',
    title: 'Paris with Family',
    blurb: 'Led family through City of Lights, navigated metro, experienced French culture',
    icon: 'tower-broadcast',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'branch-commit',
    branchLevel: 1,
    xp: 150,
  },
  {
    date: '2023-11',
    title: 'First NYC Visit',
    blurb: 'Conquered concrete jungle with family, won rat-spotting challenge',
    icon: 'building',
    iconStyle: 'solid',
    color: 'yellow',
    type: 'branch-start',
    branchLevel: 1,
    xp: 125,
  },
  {
    date: '2023-10',
    title: 'Manual F150 Mastery',
    blurb: 'Drove manual transmission truck for first time without stalling once',
    icon: 'truck',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2023-03',
    title: 'Digital Garden Launch',
    blurb: 'Published personal knowledge base and digital garden to web',
    icon: 'seedling',
    iconStyle: 'solid',
    color: 'purple',
    type: 'tag',
    tag: 'v2.5.0',
    xp: 100,
  },
  {
    date: '2021-08',
    title: 'Go Career Merge',
    blurb: 'Joined role using Go professionally after year-long learning journey',
    icon: 'code-merge',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'branch-end',
    branchLevel: 1,
    xp: 200,
  },
  {
    date: '2020-06',
    title: 'Go Journey Branch',
    blurb: 'Started 100 Days of Code with Go, building automation and DevOps tools',
    icon: 'code-branch',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'branch-start',
    branchLevel: 1,
    xp: 100,
  },
  {
    date: '2017-11',
    title: 'Family Thanksgiving',
    blurb: 'Hosted family gathering, captured memories on video',
    icon: 'turkey',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2016',
    title: 'Music Production',
    blurb: 'Dove into DAW (Studio One), exploring digital audio architecture',
    icon: 'sliders',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 75,
  },
  {
    date: '2015',
    title: 'Photography & Video',
    blurb: 'Started capturing light, crafting visual stories frame by frame',
    icon: 'camera',
    iconStyle: 'solid',
    color: 'purple',
    type: 'commit',
    xp: 200,
  },
  {
    date: '2014',
    title: 'SQL Deep Dive',
    blurb: 'Deep dive into database optimization, query tuning, schema design',
    icon: 'database',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'tag',
    tag: 'v2.0.0',
    xp: 200,
  },
  {
    date: '2012',
    title: 'PowerShell Era',
    blurb: 'Began automating everything with PowerShell scripting and pipelines',
    icon: 'bolt',
    iconStyle: 'solid',
    color: 'cyan',
    type: 'commit',
    xp: 200,
  },
  {
    date: '2010',
    title: 'Stick Shift Trial by Fire',
    blurb: 'Bought Mazdaspeed3 without knowing manual, learned through trial by fire',
    icon: 'car',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 100,
  },
  {
    date: '~2008',
    title: 'Guitar Passion',
    blurb: 'Electric and acoustic guitar became lifelong passion, post-rock soundtrack',
    icon: 'guitar',
    iconStyle: 'solid',
    color: 'purple',
    type: 'tag',
    tag: 'v1.0.0',
    xp: 150,
  },
  {
    date: '~2000s',
    title: 'Parent Class Init',
    blurb: 'Three kids, endless adventures, party leader of family expeditions',
    icon: 'baby',
    iconStyle: 'solid',
    color: 'pink',
    type: 'commit',
    xp: 500,
  },
];

const totalXP = events.reduce((sum, e) => sum + e.xp, 0);
const tags = events.filter((e) => e.type === 'tag').map((e) => e.tag);

const colorMap = {
  cyan: 'var(--sw-cyan)',
  purple: 'var(--sw-purple)',
  pink: 'var(--sw-pink)',
  yellow: 'var(--sw-yellow)',
};

const getBranchIndent = (level: number) => {
  return level * 32; // 32px per branch level
};
---

<BaseLayout title="Life Git Graph | Sheldon Hull" description="Life journey as git commits">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-bold mb-3 synthwave-gradient">
        <FAIcon style="solid" icon="code-branch" class="mr-2" />
        git log --all --graph
      </h1>
      <div class="flex justify-center gap-4 flex-wrap text-xs" style="color: var(--sw-text-muted);">
        {tags.map((tag) => (
          <span class="px-2 py-1 rounded border" style="border-color: var(--sw-cyan); color: var(--sw-cyan);">
            <FAIcon style="solid" icon="tag" class="mr-1" />
            {tag}
          </span>
        ))}
        <span style="color: var(--sw-text-secondary);">· {totalXP.toLocaleString()} XP</span>
      </div>
    </div>

    <!-- Git Graph -->
    <div class="font-mono text-sm">
      {
        events.map((event, index) => {
          const color = colorMap[event.color];
          const branchLevel = event.branchLevel || 0;
          const indent = getBranchIndent(branchLevel);
          const nextEvent = events[index + 1];
          const isBranchStart = event.type === 'branch-start';
          const isBranchEnd = event.type === 'branch-end';
          const isBranchCommit = event.type === 'branch-commit';
          const isTag = event.type === 'tag';

          return (
            <>
              {/* Tag marker */}
              {isTag && (
                <div class="flex items-center gap-2 mb-2 ml-24">
                  <div class="h-px flex-1" style={`background: ${color};`}></div>
                  <span class="text-xs px-2 py-1 rounded" style={`background: ${color}33; color: ${color};`}>
                    <FAIcon style="solid" icon="tag" class="mr-1" />
                    {event.tag}
                  </span>
                  <div class="h-px flex-1" style={`background: ${color};`}></div>
                </div>
              )}

              {/* Event */}
              <div
                class="commit-line group mb-4"
                style={`margin-left: ${indent}px;`}
                data-expanded="false"
              >
                <div class="flex items-start gap-3">
                  {/* Date */}
                  <div class="text-xs pt-1.5 w-16 flex-shrink-0" style="color: var(--sw-text-muted);">
                    {event.date}
                  </div>

                  {/* Graph connector */}
                  <div class="relative flex items-center justify-center flex-shrink-0 w-8 h-8">
                    {/* Branch line to left */}
                    {branchLevel > 0 && (isBranchStart || isBranchCommit) && (
                      <div
                        class="absolute right-full top-1/2 h-px w-8"
                        style={`background: ${color};`}
                      ></div>
                    )}
                    {branchLevel > 0 && isBranchEnd && (
                      <div
                        class="absolute right-full top-1/2 h-px w-8"
                        style={`background: ${color};`}
                      ></div>
                    )}

                    {/* Node */}
                    <div
                      class="relative z-10 w-6 h-6 rounded-full flex items-center justify-center text-xs transition-all group-hover:scale-125"
                      style={`background: ${color}; color: var(--sw-bg-primary);`}
                    >
                      <FAIcon style={event.iconStyle} icon={event.icon} />
                    </div>

                    {/* Vertical line */}
                    {nextEvent && branchLevel === 0 && (
                      <div
                        class="absolute top-full left-1/2 -translate-x-1/2 w-px h-4"
                        style="background: var(--sw-cyan);"
                      ></div>
                    )}
                    {nextEvent && branchLevel > 0 && !isBranchEnd && (
                      <div
                        class="absolute top-full left-1/2 -translate-x-1/2 w-px h-4"
                        style={`background: ${color};`}
                      ></div>
                    )}
                  </div>

                  {/* Content */}
                  <div class="flex-1 min-w-0">
                    <button
                      class="w-full text-left group/btn"
                      onclick="this.closest('.commit-line').dataset.expanded = this.closest('.commit-line').dataset.expanded === 'true' ? 'false' : 'true'"
                    >
                      <div class="flex items-baseline gap-2 flex-wrap">
                        <span class="font-semibold group-hover/btn:underline" style={`color: ${color};`}>
                          {event.title}
                        </span>
                        <span class="text-xs px-1.5 py-0.5 rounded" style={`background: ${color}22; color: ${color};`}>
                          +{event.xp}
                        </span>
                        <FAIcon
                          style="solid"
                          icon="chevron-down"
                          class="text-xs transition-transform expand-icon"
                          style={`color: ${color};`}
                        />
                      </div>
                    </button>

                    {/* Expandable blurb */}
                    <div class="blurb-content mt-2 text-xs leading-relaxed" style="color: var(--sw-text-secondary);">
                      {event.blurb}
                    </div>
                  </div>
                </div>
              </div>
            </>
          );
        })
      }

      {/* End */}
      <div class="flex items-center gap-3 ml-24 text-xs" style="color: var(--sw-text-muted);">
        <div
          class="w-3 h-3 rounded-full"
          style="background: var(--sw-cyan); box-shadow: 0 0 8px var(--sw-cyan);"
        ></div>
        <span>
          <FAIcon style="solid" icon="infinity" class="mr-1" />
          HEAD
        </span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .synthwave-gradient {
    background: linear-gradient(45deg, var(--sw-cyan), var(--sw-purple), var(--sw-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .commit-line .blurb-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .commit-line[data-expanded='true'] .blurb-content {
    max-height: 200px;
  }

  .commit-line[data-expanded='true'] .expand-icon {
    transform: rotate(180deg);
  }

  .commit-line button {
    cursor: pointer;
  }
</style>
