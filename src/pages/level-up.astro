---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';

interface Achievement {
  category: string;
  xp: number;
  year?: string;
  icon: string;
  iconStyle: 'solid' | 'brands' | 'regular';
  color: string;
  completed: boolean;
  subSkills?: string[];
}

