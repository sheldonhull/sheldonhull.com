  // Knowledge
  {
    category: 'Digital Garden',
    xp: 100,
    year: '2023',
    icon: 'seedling',
    iconStyle: 'solid',
    color: 'purple',
    completed: true,
    subSkills: ['Knowledge cultivation'],
  },
];

const totalXP = achievements.filter((a) => a.completed).reduce((sum, a) => sum + a.xp, 0);
const level = Math.floor(totalXP / 100) + 1;

const getLevelTitle = (xp: number): string => {
  if (xp < 500) return 'Newbie Adventurer';
  if (xp < 1000) return 'Code Dabbler';
  if (xp < 1500) return 'Quest Apprentice';
  if (xp < 2000) return 'Digital Wanderer';
  if (xp < 2500) return 'Skilled Journeyman';
  if (xp < 3000) return 'Tech Voyager';
  if (xp < 3500) return 'Seasoned Explorer';
  return 'Master Craftsman';
};

const colorMap = {
  cyan: 'var(--sw-cyan)',
  purple: 'var(--sw-purple)',
  pink: 'var(--sw-pink)',
  yellow: 'var(--sw-yellow)',
};
---

<BaseLayout title="Level Up - Life RPG | Sheldon Hull" description="Track achievements and skill progression RPG-style">
  <div class="max-w-4xl mx-auto">
    <!-- Hero -->
    <div class="mb-12 text-center">
      <h1 class="text-5xl font-bold mb-4 synthwave-gradient">
        <FAIcon style="solid" icon="code-branch" class="mr-3" />
        Life RPG: Skill Tree
      </h1>
      <p class="text-lg" style="color: var(--sw-text-secondary);">
        Level {level} · {getLevelTitle(totalXP)} · {totalXP.toLocaleString()} XP
      </p>
    </div>

    <!-- Git Graph Timeline -->
    <div class="relative pl-8 md:pl-12">
      <!-- Main branch line -->
      <div class="absolute left-3 md:left-5 top-0 bottom-0 w-0.5" style="background: var(--sw-cyan);"></div>

      {
        achievements.map((achievement, index) => {
          const color = colorMap[achievement.color as keyof typeof colorMap];
          const isIndented = index % 3 === 1;
          const isDoubleIndented = index % 5 === 0 && index > 0;

          return (
            <div class={`relative mb-6 ${isDoubleIndented ? 'ml-8' : isIndented ? 'ml-4' : ''}`}>
              {/* Branch line for indented items */}
              {(isIndented || isDoubleIndented) && (
                <>
                  <div
                    class="absolute -left-4 top-4 h-0.5 w-4"
                    style={`background: ${color}; opacity: 0.5;`}
                  />
                  <div
                    class="absolute -left-4 top-4 bottom-0 w-0.5"
                    style={`background: ${color}; opacity: 0.3;`}
                  />
                </>
              )}

              {/* Achievement Node */}
              <div
                class="flex items-start gap-4 p-4 rounded-lg border transition-all hover:scale-102 hover:translate-x-1 group"
                style={`background: var(--sw-bg-secondary); border-color: ${achievement.completed ? color : 'var(--sw-bg-tertiary)'};`}
              >
                {/* Icon Node */}
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-lg transition-all group-hover:scale-110"
                  style={`background: ${achievement.completed ? color : 'var(--sw-bg-tertiary)'}; opacity: ${achievement.completed ? '1' : '0.4'};`}
                >
                  <FAIcon style={achievement.iconStyle} icon={achievement.icon} class="text-[var(--sw-bg-primary)]" />
                </div>

                {/* Content */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <h3
                      class="text-lg font-bold"
                      style={`color: ${achievement.completed ? color : 'var(--sw-text-muted)'};`}
                    >
                      {achievement.category}
                    </h3>
                    {achievement.completed && (
                      <span
                        class="text-sm font-mono px-2 py-0.5 rounded"
                        style={`background: ${color}33; color: ${color};`}
                      >
                        +{achievement.xp} XP
                      </span>
                    )}
                    {achievement.year && (
                      <span class="text-xs" style="color: var(--sw-text-muted);">
                        {achievement.year}
                      </span>
                    )}
                  </div>

                  {/* Sub-skills */}
                  {achievement.subSkills && (
                    <div class="mt-2 flex flex-wrap gap-2">
                      {achievement.subSkills.map((skill) => (
                        <span
                          class="text-xs px-2 py-1 rounded"
                          style={`background: var(--sw-bg-tertiary); color: ${achievement.completed ? 'var(--sw-text-secondary)' : 'var(--sw-text-muted)'};`}
                        >
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        })
      }

      {/* End marker */}
      <div class="relative flex items-center gap-3 text-sm" style="color: var(--sw-text-muted);">
        <div
          class="w-3 h-3 rounded-full"
          style="background: var(--sw-cyan); box-shadow: 0 0 10px var(--sw-cyan);"
        ></div>
        <span>
          <FAIcon style="solid" icon="infinity" class="mr-2" />
          The adventure continues...
        </span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .synthwave-gradient {
    background: linear-gradient(45deg, var(--sw-cyan), var(--sw-purple), var(--sw-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hover\:scale-102:hover {
    transform: scale(1.02);
  }
</style>
