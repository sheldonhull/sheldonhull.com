---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAIcon from '../components/FAIcon.astro';

interface CommitNode {
  date: string;
  calver: string; // YYYY.MM format
  title: string;
  blurb: string;
  icon: string;
  iconStyle: 'solid' | 'brands' | 'regular';
  color: 'cyan' | 'purple' | 'pink' | 'yellow';
  lane: number; // 0 = main branch, 1+ = feature branches
  type: 'commit' | 'branch' | 'merge';
  branchFrom?: number; // which lane this branches from
  mergeTo?: number; // which lane this merges to
  xp: number;
}

