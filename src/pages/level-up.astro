  // Life Skills
  {
    category: 'Stick Shift Mastery',
    xp: 100,
    year: '2010',
    icon: 'car',
    iconStyle: 'solid',
    color: 'pink',
    completed: true,
    subSkills: ['Three-pedal coordination', 'Clutch control'],
  },
  {
    category: 'Beast Tamer',
    xp: 75,
    year: '2023',
    icon: 'truck',
    iconStyle: 'solid',
    color: 'pink',
    completed: true,
    subSkills: ['F150 manual transmission'],
  },

  // Travel Branch
  {
    category: 'NYC Adventure',
    xp: 125,
    year: '2023',
    icon: 'building',
    iconStyle: 'solid',
    color: 'yellow',
    completed: true,
    subSkills: ['Concrete jungle navigation', 'Urban rodent tracking'],
  },
  {
    category: 'Paris Expedition',
    xp: 150,
    year: '2023',
    icon: 'tower-broadcast',
    iconStyle: 'solid',
    color: 'yellow',
    completed: true,
    subSkills: ['City of lights exploration', 'Underground metro mastery'],
  },
  {
    category: 'European Rail Journey',
    xp: 125,
    year: '2023',
    icon: 'train',
    iconStyle: 'solid',
    color: 'yellow',
    completed: true,
    subSkills: ['Chunnel crossing', 'London pub questing'],
  },
  {
    category: 'Palace Grounds',
    xp: 100,
    year: '2023',
    icon: 'monument',
    iconStyle: 'solid',
    color: 'yellow',
    completed: true,
    subSkills: ['Versailles wanderer'],
  },

  // Family
  {
    category: 'Parent Class',
    xp: 500,
    icon: 'baby',
    iconStyle: 'solid',
    color: 'pink',
    completed: true,
    subSkills: ['Dad life unlocked', 'Party leadership'],
  },
  {
    category: 'Memory Keeper',
    xp: 175,
    year: '2017-2023',
    icon: 'video',
    iconStyle: 'solid',
    color: 'pink',
    completed: true,
    subSkills: ['Family videography', 'Thanksgiving hosting'],
  },

  // Creative Arts Branch
  {
    category: 'Six-String Bard',
    xp: 150,
    icon: 'guitar',
    iconStyle: 'solid',
    color: 'purple',
    completed: true,
    subSkills: ['Electric & acoustic mastery'],
  },
  {
    category: 'Visual Storytelling',
    xp: 200,
    icon: 'camera',
    iconStyle: 'solid',
    color: 'purple',
    completed: true,
    subSkills: ['Light catching', 'Frame-by-frame artisan'],
  },
  {
    category: 'Sonic Landscape',
    xp: 150,
    year: '2016',
    icon: 'music',
    iconStyle: 'solid',
    color: 'purple',
    completed: true,
    subSkills: ['Post-rock curation', 'Digital audio architecture'],
  },

  // Code Branch
  {
    category: 'SQL Sorcery',
    xp: 200,
    icon: 'database',
    iconStyle: 'solid',
    color: 'cyan',
    completed: true,
    subSkills: ['Query optimization', 'Schema design'],
  },
  {
    category: 'PowerShell Wizardry',
    xp: 200,
    icon: 'bolt',
    iconStyle: 'solid',
    color: 'cyan',
    completed: true,
