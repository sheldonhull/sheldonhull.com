  },

  // Infrastructure
  {
    category: 'Container Wrangling',
    xp: 100,
    icon: 'docker',
    iconStyle: 'brands',
    color: 'cyan',
    completed: true,
    subSkills: ['Docker containerization'],
  },
  {
    category: 'Pipeline Architecture',
    xp: 150,
    icon: 'circle-nodes',
    iconStyle: 'solid',
    color: 'cyan',
    completed: true,
    subSkills: ['CI/CD automation'],
