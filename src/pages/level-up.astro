    color: 'purple',
    lane: 0,
    type: 'commit',
    xp: 150,
  },
];

const totalXP = commits.reduce((sum, c) => sum + c.xp, 0);

const colorMap = {
  cyan: '#7FDBCA',
  purple: '#C792EA',
  pink: '#FF5874',
  yellow: '#ECC48D',
};

// Group by CalVer for display
const calverGroups = commits.reduce(
  (groups, commit) => {
    if (!groups[commit.calver]) {
      groups[commit.calver] = [];
    }
    groups[commit.calver].push(commit);
    return groups;
  },
  {} as Record<string, CommitNode[]>
);
---

<BaseLayout title="git log --graph --all | Sheldon Hull" description="Life as git commits">
  <div class="max-w-5xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2 synthwave-gradient font-mono">
        <FAIcon style="solid" icon="code-branch" class="mr-2" />
        git log --graph --all --oneline
      </h1>
      <div class="text-sm font-mono" style="color: var(--sw-text-muted);">
        {Object.keys(calverGroups).length} releases · {totalXP.toLocaleString()} commits
      </div>
    </div>

    <!-- Git Graph -->
    <div class="git-graph">
      {
        commits.map((commit, index) => {
          const nextCommit = commits[index + 1];
          const prevCommit = commits[index - 1];
          const color = colorMap[commit.color];
          const laneOffset = commit.lane * 40;

          return (
            <div class="commit-row group" data-lane={commit.lane}>
              {/* Graph visualization */}
              <div class="graph-container">
                <svg class="graph-svg" viewBox="0 0 200 80" preserveAspectRatio="xMinYMin meet">
                  {/* Main branch line */}
                  {commit.lane === 0 && nextCommit && (
                    <line x1="20" y1="40" x2="20" y2="80" stroke="var(--sw-cyan)" stroke-width="2" />
                  )}

                  {/* Branch line */}
                  {commit.lane > 0 && nextCommit && nextCommit.lane === commit.lane && (
                    <line
                      x1={20 + commit.lane * 40}
                      y1="40"
                      x2={20 + commit.lane * 40}
                      y2="80"
                      stroke={color}
                      stroke-width="2"
                    />
                  )}

                  {/* Branch creation curve */}
                  {commit.type === 'branch' && (
                    <path
                      d={`M 20 40 Q 30 40, ${20 + 40} 50 L ${20 + 40} 80`}
                      stroke={color}
                      stroke-width="2"
                      fill="none"
                    />
                  )}

                  {/* Merge curve */}
                  {commit.type === 'merge' && commit.mergeTo !== undefined && (
                    <path
                      d={`M ${20 + commit.lane * 40} 0 L ${20 + commit.lane * 40} 30 Q ${20 + commit.lane * 40} 40, ${20 + commit.mergeTo * 40} 40`}
                      stroke={color}
                      stroke-width="2"
                      fill="none"
                    />
                  )}

                  {/* Commit node */}
                  <circle
                    cx={20 + commit.lane * 40}
                    cy="40"
                    r="8"
                    fill={color}
                    class="commit-node"
                    stroke="var(--sw-bg-primary)"
                    stroke-width="2"
                  />

                  {/* Icon in node */}
                  <foreignObject x={20 + commit.lane * 40 - 6} y="34" width="12" height="12">
                    <div class="node-icon" style={`color: var(--sw-bg-primary);`}>
                      <FAIcon style={commit.iconStyle} icon={commit.icon} />
                    </div>
                  </foreignObject>
                </svg>
              </div>

              {/* Commit content */}
              <div class="commit-content">
                <div class="commit-header">
                  <span class="calver" style={`color: ${color};`}>{commit.calver}</span>
                  <button
                    class="commit-title"
                    onclick="this.closest('.commit-row').classList.toggle('expanded')"
                    style={`color: ${color};`}
                  >
                    {commit.title}
                    <span class="xp-badge" style={`background: ${color}22; color: ${color};`}>+{commit.xp}</span>
                    <FAIcon style="solid" icon="chevron-down" class="expand-chevron" />
                  </button>
                </div>
                <div class="commit-blurb" style="color: var(--sw-text-secondary);">{commit.blurb}</div>
              </div>
            </div>
          );
        })
      }

      {/* HEAD marker */}
      <div class="head-marker">
        <svg class="graph-svg" viewBox="0 0 200 40" preserveAspectRatio="xMinYMin meet">
          <circle cx="20" cy="20" r="6" fill="var(--sw-cyan)" class="pulse" />
        </svg>
        <span class="head-text" style="color: var(--sw-cyan);">
          <FAIcon style="solid" icon="infinity" class="mr-1" />
          HEAD
        </span>
      </div>
    </div>

    <!-- Mermaid Comparison -->
    <div class="mt-16 border-t pt-12" style="border-color: var(--sw-bg-tertiary);">
      <div class="mb-6">
        <h2 class="text-2xl font-bold mb-2 synthwave-gradient font-mono">
          <FAIcon style="solid" icon="diagram-project" class="mr-2" />
          Mermaid Gitgraph (Comparison)
        </h2>
        <p class="text-sm" style="color: var(--sw-text-muted);">
          Alternative visualization using Mermaid.js with custom theming
        </p>
      </div>

      <div class="mermaid-container">
        <pre class="mermaid">
%%{init: {
  'theme': 'base',
  'themeVariables': {
    'git0': '#7FDBCA',
    'git1': '#C792EA',
    'git2': '#FF5874',
    'git3': '#ECC48D',
    'gitBranchLabel0': '#7FDBCA',
    'gitBranchLabel1': '#C792EA',
    'gitBranchLabel2': '#FF5874',
    'gitBranchLabel3': '#ECC48D',
    'commitLabelColor': '#FFFFFF',
    'commitLabelBackground': '#1A1B26',
    'commitLabelFontSize': '12px',
    'tagLabelColor': '#FFFFFF',
    'tagLabelBackground': '#7FDBCA',
    'tagLabelBorder': '#7FDBCA',
    'tagLabelFontSize': '10px'
  },
  'gitGraph': {
    'mainBranchName': 'life',
    'showCommitLabel': true,
    'rotateCommitLabel': false
  }
}%%
gitGraph TB:
  commit id: "2008.01 Guitar Passion" tag: "🎸"
  commit id: "2010.01 Stick Shift" tag: "🚗"
  commit id: "2012.01 PowerShell Era" tag: "⚡"
  commit id: "2014.05 SQL Deep Dive" tag: "🗄️"
  commit id: "2015.10 Photography" tag: "📷"
  commit id: "2016.09 Music Production" tag: "🎚️"
  commit id: "2017.11 Thanksgiving" tag: "🦃"
  branch go-journey
  checkout go-journey
  commit id: "2020.06 Go Learning" tag: "🔀"
  checkout life
  commit id: "2023.03 Digital Garden" tag: "🌱"
  commit id: "2023.10 F150 Manual" tag: "🛻"
  branch europe-travel
  checkout europe-travel
  commit id: "2023.11 NYC Visit" tag: "🏙️"
  commit id: "2023.11 Paris" tag: "🗼"
  commit id: "2023.11 Versailles" tag: "🏛️"
  commit id: "2023.12 London" tag: "🚄"
  checkout life
  merge europe-travel tag: "merge-europe"
  checkout go-journey
  commit id: "2021.08 Go Career" tag: "🔗"
  checkout life
  merge go-journey tag: "merge-go"
  commit id: "2023.12 AI Exploration" tag: "🤖"
  commit id: "2024.10 AI Diagnostics" tag: "🧠"
  commit id: "2025.11 Astro Migration" tag: "🚀"
        </pre>
      </div>

      <div class="text-xs mt-4 p-4 rounded" style="background: var(--sw-bg-secondary); color: var(--sw-text-muted);">
        <strong>Comparison Notes:</strong> Mermaid provides automatic layout but less customization.
        Custom SVG version above offers more control over styling and interactivity.
      </div>
    </div>
  </div>
</BaseLayout>

<!-- Mermaid.js -->
<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  mermaid.initialize({
    startOnLoad: true,
    theme: 'base',
    themeVariables: {
      darkMode: true,
      background: '#1A1B26',
      primaryColor: '#7FDBCA',
      primaryTextColor: '#FFFFFF',
      primaryBorderColor: '#7FDBCA',
      lineColor: '#7FDBCA',
      secondaryColor: '#C792EA',
      tertiaryColor: '#FF5874',
      fontSize: '12px',
      fontFamily: 'Monaco, Menlo, Ubuntu Mono, monospace'
    },
    gitGraph: {
      mainBranchName: 'life',
      mainBranchOrder: 0,
      showCommitLabel: true,
      showBranches: true,
      rotateCommitLabel: false
    }
  });
</script>

<style>
  .synthwave-gradient {
    background: linear-gradient(45deg, var(--sw-cyan), var(--sw-purple), var(--sw-pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .git-graph {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 13px;
  }

  .commit-row {
    display: flex;
    gap: 16px;
    margin-bottom: 0;
    min-height: 80px;
    position: relative;
  }

  .graph-container {
    flex-shrink: 0;
    width: 200px;
  }

  .graph-svg {
    width: 100%;
    height: 80px;
  }

  .commit-node {
    transition: r 0.2s ease;
  }

  .commit-row:hover .commit-node {
    r: 10;
  }

  .node-icon {
    font-size: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .commit-content {
    flex: 1;
    min-width: 0;
    padding-top: 24px;
  }

  .commit-header {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .calver {
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
    min-width: 70px;
  }

  .commit-title {
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    padding: 0;
    transition: opacity 0.2s ease;
  }

  .commit-title:hover {
    opacity: 0.8;
  }

  .xp-badge {
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 500;
  }

  .expand-chevron {
    font-size: 10px;
    transition: transform 0.3s ease;
  }

  .commit-row.expanded .expand-chevron {
    transform: rotate(180deg);
  }

  .commit-blurb {
    font-size: 12px;
    line-height: 1.5;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, margin-top 0.3s ease;
    padding-left: 82px;
  }

  .commit-row.expanded .commit-blurb {
    max-height: 100px;
    margin-top: 4px;
  }

  .head-marker {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-top: 12px;
    padding-left: 8px;
  }

  .head-marker .graph-svg {
    width: 200px;
    height: 40px;
  }

  .head-text {
    font-weight: 600;
    font-size: 12px;
  }

  .pulse {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 4px currentColor);
    }
    50% {
      opacity: 0.6;
      filter: drop-shadow(0 0 8px currentColor);
    }
  }

  @media (max-width: 768px) {
    .graph-container {
      width: 120px;
    }

    .commit-blurb {
      padding-left: 0;
    }
  }

  /* Mermaid styling */
  .mermaid-container {
    background: var(--sw-bg-secondary);
    border-radius: 8px;
    padding: 24px;
    overflow-x: auto;
  }

  .mermaid-container pre {
    margin: 0;
    background: transparent;
  }

  /* Override Mermaid defaults to match theme */
  :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
  }

  :global(.mermaid .commit-label) {
    fill: var(--sw-text-primary) !important;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important;
    font-size: 11px !important;
  }

  :global(.mermaid .branch-label) {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important;
    font-weight: 600 !important;
  }
</style>
