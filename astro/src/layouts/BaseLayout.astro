---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sheldon Hull",
  description = "Tech blog and digital garden by Sheldon Hull"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-[var(--sw-text-primary)]" style="background: var(--sw-bg-primary);">
    <nav class="border-b backdrop-blur-sm" style="border-color: var(--sw-cyan); background: var(--sw-bg-secondary);">
      <div class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-xl font-bold transition-all hover:scale-105" style="color: var(--sw-cyan);">
            Sheldon Hull
          </a>
          <div class="flex gap-6">
            <a href="/" class="transition-colors hover:text-[var(--sw-cyan)]" style="color: var(--sw-text-secondary);">Home</a>
            <a href="/posts" class="transition-colors hover:text-[var(--sw-cyan)]" style="color: var(--sw-text-secondary);">Posts</a>
            <a href="/about" class="transition-colors hover:text-[var(--sw-cyan)]" style="color: var(--sw-text-secondary);">About</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-4 py-12">
      <slot />
    </main>

    <footer class="border-t mt-16" style="border-color: var(--sw-bg-tertiary); background: var(--sw-bg-secondary);">
      <div class="container mx-auto px-4 py-8 text-center text-sm" style="color: var(--sw-text-muted);">
        <p>&copy; {new Date().getFullYear()} Sheldon Hull. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
