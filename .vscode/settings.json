{
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.fontSize": 14,
    "editor.lineHeight": 26
  },
  "grammarly.files.include": [
    "*.md"
  ],
  "grammarly.userWords": [
    "CLI",
    "Localdb",
    "cli",
    "dbaconnection",
    "dbatools",
    "docset",
    "gists",
    "ldf",
    "localdb",
    "mdf",
    "omitempty",
    "pwsh"
  ],
  "branchwarnings.protectedBranches": [],
  "conventionalCommits.scopes": [
    "blog",
    "build",
    "microblog",
    "style",
    "config",
    "docs",
    "codespaces",
    "brag",
    "vscode",
    "layout",
    "rss",
    "tasks",
    "project",
    "docker",
    "deps",
    "astro"
  ],
  "conventionalCommits.emojiFormat": "emoji",
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.autoIndent": "advanced",
  },
  "staticWebApps.appSubpath": "/",
  "staticWebApps.apiSubpath": "/",
  "staticWebApps.appArtifactSubpath": "build",
  "git.autoRepositoryDetection": false,
  "git.ignoredRepositories": [
    "codeit"
  ],
  "conventionalCommits.showNewVersionNotes": true,
  "git.ignoreSubmodules": true,
  "scm.repositories.visible": 1,
  "files.exclude": {
    "**/.git": false,
    "**/.svn": false,
    "**/.hg": false,
    "**/CVS": false,
    "**/.DS_Store": false,
    "**/Thumbs.db": false,
    ".prettierrc": false,
    ".run": false,
    "**/renovate.json": false,
    ".*.y*ml": false,
    ".git*": false,
    ".devcontainer": false,
    ".vscode": false,
    "LICENSE": false,
    "artifacts": false,
    "node_modules": false,
    "package-lock.json": false,
    "public": false,
    "readme.md": false,
    "scripts": false,
    "static": false,
    "**/yarn.lock": false,
  },
  "explorerExclude.backup": null,
  "grammarly.selectors": [
    {
      "language": "markdown",
      "scheme": "file",
      "pattern": "src/content/posts/2023/**/*.mdx"
    }
  ],
}
